---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { loadCity, loadCorporation, loadAllCategories, loadMergedItems } from "../../lib/data-loader";
import { editorForToken } from "../../lib/supabase";
import { formatINR } from "../../lib/format";

const CITY_ID = "bengaluru";
const { corporation: corpId } = Astro.params;

const city = loadCity(CITY_ID);
const corporation = loadCorporation(CITY_ID, corpId!);
if (!city || !corporation) return Astro.redirect("/404");

// Goals/Budget tabs are hidden this phase — bounce legacy query strings home.
const view = Astro.url.searchParams.get("view");
if (view === "goals" || view === "budget") {
  return Astro.redirect(`/${corporation.id}`);
}

const { loadCategoryOrder } = await import("../../lib/supabase");
const [categories, items, explicitOrder] = await Promise.all([
  loadAllCategories(CITY_ID, corporation.id),
  loadMergedItems(CITY_ID, corporation.id),
  loadCategoryOrder(corporation.id),
]);

// If a valid review token is present (cookie or ?token=), this page becomes
// editable: cards get drag handles. Public viewers without a token see the
// normal read-only grid.
const cookieToken = Astro.cookies.get("review_token")?.value ?? null;
const urlToken = Astro.url.searchParams.get("token") ?? null;

// If the cookie holds a valid token but the URL doesn't, surface it in the
// URL bar so editors always see the shareable URL.
if (!urlToken && cookieToken && editorForToken(cookieToken)) {
  return Astro.redirect(`/${corporation.id}?token=${encodeURIComponent(cookieToken)}`);
}

const reviewerName = editorForToken(cookieToken) || editorForToken(urlToken);
const isEditor = !!reviewerName;
const activeToken = editorForToken(urlToken) ? urlToken : (editorForToken(cookieToken) ? cookieToken : null);

if (urlToken && urlToken !== cookieToken && editorForToken(urlToken)) {
  Astro.cookies.set("review_token", urlToken, {
    path: "/", httpOnly: false, sameSite: "lax", maxAge: 60 * 60 * 24 * 30,
  });
}

const byCat = new Map<string, typeof items>();
for (const it of items) {
  const key = it.effective_category;
  if (!byCat.has(key)) byCat.set(key, []);
  byCat.get(key)!.push(it);
}

const ITEMS_PER_CARD = 4;
const totalAmountLakhs = items
  .filter((i) => i.amount_lakhs != null)
  .reduce((sum, i) => sum + (i.amount_lakhs ?? 0), 0);

const gridCards = categories
  .map((cat) => {
    const catItems = byCat.get(cat.code) ?? [];
    const amount = catItems
      .filter((i) => i.amount_lakhs != null)
      .reduce((sum, i) => sum + (i.amount_lakhs ?? 0), 0);
    const sorted = [...catItems].sort((a, b) => (b.amount_lakhs ?? 0) - (a.amount_lakhs ?? 0));
    return {
      code: cat.code,
      title: cat.title,
      titleLocal: cat.title_local,
      amount,
      share: totalAmountLakhs > 0 ? amount / totalAmountLakhs : 0,
      itemCount: catItems.length,
      highlights: sorted.slice(0, ITEMS_PER_CARD),
    };
  })
  .filter((c) => c.itemCount > 0)
  // Explicit order first (set by editor), fallback amount desc.
  .sort((a, b) => {
    const aH = explicitOrder.has(a.code), bH = explicitOrder.has(b.code);
    if (aH && bH) return (explicitOrder.get(a.code) ?? 0) - (explicitOrder.get(b.code) ?? 0);
    if (aH) return -1;
    if (bH) return 1;
    return b.amount - a.amount;
  });
---

<BaseLayout
  title={`${corporation.name} Budget 2026-27`}
  description={`Goals and allocations from the ${corporation.name} budget speech`}
  mastheadTitle={corporation.name.replace(" City Corporation", "")}
  mastheadSubtitle={`Goals from the Budget Speech 2026-27, organised by the Commissioner's own sections`}
  mastheadHref="/"
>
  <Fragment slot="masthead-nav">
    <a href={`/${corporation.id}`} class="is-active">Summary</a>
    <a href="/about">About</a>
  </Fragment>

  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: corporation.name.replace(" City Corporation", "") },
    ]}
  />

  {isEditor && (
    <div class="edit-bar">
      <span class="edit-bar__label"><i class="fa-solid fa-pen-to-square"></i> Editor mode · {reviewerName}</span>
      <button type="button" class="edit-bar__toggle" id="reorder-toggle">
        <i class="fa-solid fa-up-down-left-right"></i> Reorder cards
      </button>
      <a href={`/review/${corporation.id}${activeToken ? `?token=${activeToken}` : ""}`} class="edit-bar__link">Review items →</a>
    </div>
  )}

  <section class="cat-grid" id="cat-grid">
    {gridCards.map((c) => (
      <article class="cat-card" data-cat={c.code} data-cat-code={c.code}>
        <div class="cat-card__head">
          <h3 class="cat-card__name">{c.title}</h3>
          {c.titleLocal && <span class="cat-card__local">{c.titleLocal}</span>}
        </div>

        <div class="cat-card__summary">
          <span class="cat-card__amount">{c.amount > 0 ? formatINR(c.amount) : "—"}</span>
          <span class="cat-card__meta">
            {c.itemCount} {c.itemCount === 1 ? "item" : "items"}
            {c.amount > 0 && ` · ${(c.share * 100).toFixed(1)}% of speech amount`}
          </span>
        </div>

        {c.highlights.length > 0 && (
          <ul class="cat-card__highlights">
            {c.highlights.map((h) => (
              <li class="cat-card__hl">
                <a href={`/${corporation.id}/category/${c.code}`} class="cat-card__hl-link" title={h.description || h.name}>
                  <span class="cat-card__hl-name">{h.name}</span>
                  {h.amount_lakhs != null && (
                    <span class="cat-card__hl-amt">{formatINR(h.amount_lakhs)}</span>
                  )}
                </a>
              </li>
            ))}
          </ul>
        )}

        <div class="cat-card__foot">
          {c.itemCount > c.highlights.length ? (
            <a href={`/${corporation.id}/category/${c.code}`} class="cat-card__more">
              {c.itemCount - c.highlights.length} more <i class="fa-solid fa-arrow-right"></i>
            </a>
          ) : (
            <a href={`/${corporation.id}/category/${c.code}`} class="cat-card__more">
              View all <i class="fa-solid fa-arrow-right"></i>
            </a>
          )}
        </div>
      </article>
    ))}
  </section>

  <p class="source-line">
    Source: Commissioner's Budget Speech 2026-27 for {corporation.name}. Items organised by the speech's own section headings. Reviewer overrides apply live.
  </p>
</BaseLayout>

<div data-realtime-corp={corporation.id} data-is-editor={isEditor ? "1" : "0"} hidden></div>
<script>
  import { subscribeCorpRealtime } from "../../lib/realtime-client";
  const el = document.querySelector("[data-realtime-corp]");
  if (el) subscribeCorpRealtime(el.getAttribute("data-realtime-corp"));

  const isEditor = el?.getAttribute("data-is-editor") === "1";
  const corpId = el?.getAttribute("data-realtime-corp");
  if (isEditor && corpId) {
    const grid = document.getElementById("cat-grid");
    const toggle = document.getElementById("reorder-toggle");
    let active = false;
    let dragged: HTMLElement | null = null;

    function setActive(on: boolean) {
      active = on;
      grid?.classList.toggle("reordering", on);
      toggle?.classList.toggle("is-active", on);
      grid?.querySelectorAll<HTMLElement>(".cat-card").forEach((c) => {
        c.draggable = on;
      });
    }

    toggle?.addEventListener("click", () => setActive(!active));

    grid?.addEventListener("dragstart", (e) => {
      const card = (e.target as HTMLElement).closest<HTMLElement>(".cat-card");
      if (!card || !active) return;
      dragged = card;
      card.classList.add("dragging");
      e.dataTransfer?.setData("text/plain", card.dataset.catCode || "");
      if (e.dataTransfer) e.dataTransfer.effectAllowed = "move";
    });

    grid?.addEventListener("dragend", () => {
      dragged?.classList.remove("dragging");
      dragged = null;
    });

    grid?.addEventListener("dragover", (e) => {
      if (!active || !dragged) return;
      e.preventDefault();
      const target = (e.target as HTMLElement).closest<HTMLElement>(".cat-card");
      if (!target || target === dragged || !grid) return;
      const cards = Array.from(grid.children) as HTMLElement[];
      const draggedIdx = cards.indexOf(dragged);
      const targetIdx = cards.indexOf(target);
      if (draggedIdx < targetIdx) target.after(dragged);
      else target.before(dragged);
    });

    grid?.addEventListener("drop", async (e) => {
      if (!active) return;
      e.preventDefault();
      const order = Array.from(grid.querySelectorAll<HTMLElement>(".cat-card"))
        .map((c) => c.dataset.catCode!)
        .filter(Boolean);
      try {
        const res = await fetch("/api/review/category-order", {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ corpId, order }),
        });
        if (!res.ok) throw new Error(await res.text());
      } catch (err) {
        console.error("Reorder save failed", err);
      }
    });
  }
</script>

<style>
  :root {
    --num-font: "Inter", ui-sans-serif, system-ui, sans-serif;
    --c-ink: #1a202c;
    --c-ink-soft: #4a5568;
    --c-rule: #e2e8f0;
    --c-rule-soft: #edf2f7;
    --c-neutral: #718096;
  }

  /* Category palette — same hues shared with /review/[corp] and /{corp}/category/{c}. */
  [data-cat="administration"],
  [data-cat="finance-and-accounts"],
  [data-cat="public-relations"]           { --cat-c: #52525b; --cat-bg: #f4f4f5; }
  [data-cat="revenue"],
  [data-cat="advertisement"],
  [data-cat="markets"],
  [data-cat="properties"],
  [data-cat="assets"]                     { --cat-c: #b45309; --cat-bg: #fef3c7; }
  [data-cat="land-acquisition"],
  [data-cat="urban-planning"]             { --cat-c: #c2410c; --cat-bg: #ffedd5; }
  [data-cat="public-works"],
  [data-cat="lakes-division"],
  [data-cat="storm-water-drains"]         { --cat-c: #1d4ed8; --cat-bg: #dbeafe; }
  [data-cat="education"]                  { --cat-c: #6d28d9; --cat-bg: #ede9fe; }
  [data-cat="forestry"],
  [data-cat="urban-forestry"]             { --cat-c: #166534; --cat-bg: #dcfce7; }
  [data-cat="horticulture"]               { --cat-c: #4d7c0f; --cat-bg: #ecfccb; }
  [data-cat="health"],
  [data-cat="health-department-clinical"] { --cat-c: #9d174d; --cat-bg: #fce7f3; }
  [data-cat="sanitation"]                 { --cat-c: #0f766e; --cat-bg: #ccfbf1; }
  [data-cat="animal-husbandry"]           { --cat-c: #b91c1c; --cat-bg: #fee2e2; }
  [data-cat="welfare"]                    { --cat-c: #4338ca; --cat-bg: #e0e7ff; }
  [data-cat="budget-summary"]             { --cat-c: #475569; --cat-bg: #f1f5f9; }

  .edit-bar {
    margin-top: 1.2rem;
    display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;
    background: #fffbeb; border: 1px solid #fcd34d;
    border-radius: 5px; padding: 0.5rem 0.85rem;
    font-size: 0.85rem; color: #78350f;
  }
  .edit-bar__label { font-weight: 600; }
  .edit-bar__label i { margin-right: 0.3rem; }
  .edit-bar__toggle {
    font: inherit; font-size: 0.82rem; font-weight: 600;
    padding: 0.3rem 0.7rem; border-radius: 4px;
    background: #fff; color: #78350f;
    border: 1px solid #fcd34d; cursor: pointer;
  }
  .edit-bar__toggle:hover { background: #fef3c7; }
  .edit-bar__toggle.is-active { background: #78350f; color: #fff; border-color: #78350f; }
  .edit-bar__toggle i { margin-right: 0.25rem; }
  .edit-bar__link { margin-left: auto; color: #78350f; font-weight: 600; text-decoration: none; }
  .edit-bar__link:hover { text-decoration: underline; }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.9rem;
    margin-top: 1.5rem;
  }
  .cat-grid.reordering .cat-card {
    cursor: grab;
    user-select: none;
    box-shadow: 0 2px 6px rgba(0,0,0,0.06);
  }
  .cat-grid.reordering .cat-card::after {
    content: "↕"; position: absolute; top: 0.5rem; right: 0.6rem;
    font-size: 0.85rem; color: var(--cat-c, #4a5568);
    background: rgba(255,255,255,0.85);
    width: 22px; height: 22px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .cat-card { position: relative; }
  .cat-card.dragging { opacity: 0.5; cursor: grabbing; }
  @media (max-width: 1000px) {
    .cat-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 720px) {
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .cat-grid { grid-template-columns: 1fr; }
  }

  .cat-card {
    display: flex; flex-direction: column;
    background: #fff;
    border: 1px solid #cbd5e0;
    border-radius: 6px; overflow: hidden;
    box-shadow: 0 1px 0 rgba(0,0,0,0.03);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .cat-card:hover {
    border-color: var(--cat-c, #3F5F7A);
    box-shadow: 0 4px 12px rgba(63,95,122,0.1);
  }

  .cat-card__head {
    display: flex; flex-direction: column; gap: 0.1rem;
    padding: 0.7rem 1rem;
    background: var(--cat-bg, var(--c-rule-soft));
    border-bottom: 1px solid rgba(0,0,0,0.06);
    border-left: 3px solid var(--cat-c, #3F5F7A);
  }
  .cat-card__name {
    font-size: 0.98rem; font-weight: 700;
    color: var(--cat-c, var(--c-ink));
    line-height: 1.25; letter-spacing: -0.005em; margin: 0;
  }
  .cat-card__local {
    font-size: 0.76rem; font-weight: 500;
    color: var(--c-neutral); line-height: 1.2;
  }

  .cat-card > *:not(.cat-card__head) { padding-left: 1rem; padding-right: 1rem; }
  .cat-card__summary {
    display: flex; flex-direction: column; gap: 0.05rem;
    padding-top: 0.85rem; padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .cat-card__amount {
    font-family: var(--num-font); font-variant-numeric: tabular-nums;
    font-size: 1.25rem; font-weight: 800; letter-spacing: -0.015em;
    color: var(--c-ink); line-height: 1.1;
  }
  .cat-card__meta { font-size: 0.72rem; color: var(--c-neutral); }

  .cat-card__highlights {
    list-style: none; padding-top: 0.4rem; display: flex; flex-direction: column; gap: 0;
  }
  .cat-card__hl { margin: 0; }
  .cat-card__hl-link {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 0.55rem; padding: 0.35rem 0;
    color: var(--c-ink); text-decoration: none;
    border-bottom: 1px solid var(--c-rule-soft);
    transition: color 0.12s;
  }
  .cat-card__hl:last-child .cat-card__hl-link { border-bottom: 0; }
  .cat-card__hl-link:hover { color: var(--cat-c, #3F5F7A); }
  .cat-card__hl-name {
    font-size: 0.8rem; line-height: 1.3; flex: 1;
    overflow: hidden; display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
  .cat-card__hl-amt {
    font-size: 0.72rem; font-weight: 700;
    color: var(--c-ink-soft); font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }

  .cat-card__foot { padding-top: 0.5rem; padding-bottom: 0.85rem; }
  .cat-card__more {
    font-size: 0.78rem; font-weight: 600;
    color: var(--cat-c, #3F5F7A); text-decoration: none;
    display: inline-flex; align-items: center; gap: 0.3rem;
  }
  .cat-card__more:hover { text-decoration: underline; }

  .source-line {
    font-size: 0.78rem; color: var(--c-neutral);
    margin-top: 2rem; padding-top: 1rem;
    border-top: 1px solid var(--c-rule);
    line-height: 1.55;
  }
</style>
