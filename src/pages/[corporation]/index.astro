---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { loadCity, loadCorporation, loadLineItemBudget, loadSpeechProjects } from "../../lib/data-loader";
import { formatINR } from "../../lib/format";

// City is fixed internally; URLs are corporation-scoped only
const CITY_ID = "bengaluru";
const { corporation: corpId } = Astro.params;

const city = loadCity(CITY_ID);
const corporation = loadCorporation(CITY_ID, corpId!);

if (!city || !corporation) {
  return Astro.redirect("/404");
}

const data = loadLineItemBudget(city.id, corporation.id);
const speech = loadSpeechProjects(city.id, corporation.id);

const view = (Astro.url.searchParams.get("view") ?? "summary") as "summary" | "goals" | "budget";

// Group speech projects by function_code
type SpeechProj = NonNullable<typeof speech>["projects"][number];
const projectsByFn = new Map<string, SpeechProj[]>();
for (const p of speech?.projects ?? []) {
  const code = p.function_code ?? "unmapped";
  if (!projectsByFn.has(code)) projectsByFn.set(code, []);
  projectsByFn.get(code)!.push(p);
}

// Function meta in display order (matches budget functions)
const FUNCTION_ORDER = [
  { code: "01", name: "Council" },
  { code: "02", name: "General Administration" },
  { code: "03", name: "Revenue" },
  { code: "04", name: "Town Planning and Regulation" },
  { code: "05", name: "Public Works" },
  { code: "06", name: "Solid Waste Management" },
  { code: "07", name: "Public Health-General" },
  { code: "08", name: "Public Health-Medical" },
  { code: "09", name: "Horticulture" },
  { code: "10", name: "Urban Forestry" },
  { code: "11", name: "Public Education" },
  { code: "12", name: "Social Welfare" },
];

// Build grid cards from line-item data, in fixed FUNCTION_ORDER so the 3x4 is stable
const fnByCode = new Map((data?.functions ?? []).map((f) => [f.code, f]));
const totalAllFns = (data?.functions ?? []).reduce((sum, f) => sum + f.total_2026_27, 0);

// Pick up to 3 speech highlights per function: amounted first (desc by amount),
// then by speech order to fill the slot.
const HIGHLIGHTS_PER_CARD = 3;
function pickHighlights(code: string): SpeechProj[] {
  const items = projectsByFn.get(code) ?? [];
  const amounted = items
    .filter((p) => p.amount_lakhs != null)
    .sort((a, b) => (b.amount_lakhs ?? 0) - (a.amount_lakhs ?? 0));
  const rest = items.filter((p) => p.amount_lakhs == null);
  return [...amounted, ...rest].slice(0, HIGHLIGHTS_PER_CARD);
}

// Council (01) has no goals — it's just the elected body's establishment costs.
// Hide it from the Summary grid; it remains reachable via the Budget view.
// Sort by expenditure (highest first) so scale is the first axis of comparison.
const gridCards = FUNCTION_ORDER
  .filter((f) => f.code !== "01")
  .map((f) => {
    const fn = fnByCode.get(f.code);
    const amount = fn?.total_2026_27 ?? 0;
    const share = totalAllFns > 0 ? amount / totalAllFns : 0;
    const items = projectsByFn.get(f.code) ?? [];
    const highlights = pickHighlights(f.code);
    return {
      code: f.code,
      name: f.name,
      amount,
      share,
      projectCount: items.length,
      highlights,
    };
  })
  .sort((a, b) => b.amount - a.amount);

function fmtYoY(pct: number | null | undefined): string {
  if (pct === null || pct === undefined) return "";
  const sign = pct >= 0 ? "+" : "";
  return `${sign}${pct.toFixed(1)}%`;
}

function yoyClass(pct: number | null | undefined): string {
  if (pct === null || pct === undefined) return "yoy-none";
  if (pct > 0) return "yoy-up";
  if (pct < 0) return "yoy-down";
  return "yoy-zero";
}

function cleanName(s: string): string {
  // Strip stray em-dashes, double-spaces, orphan commas/punctuation
  return s
    .replace(/\s[—–]\s/g, ", ")
    .replace(/\s*,\s*,+/g, ", ")
    .replace(/\s{2,}/g, " ")
    .replace(/[,.\s]+$/g, "")
    .trim();
}
---

<BaseLayout
  title={`${corporation.name} Budget ${data?.fiscal_year ?? "2026-27"}`}
  description={`Public finances and program of works for ${corporation.name}`}
  mastheadTitle={corporation.name.replace(" City Corporation", "")}
  mastheadSubtitle={`Public Finances and Program of Works, fiscal year ${data?.fiscal_year ?? "2026-27"}`}
  mastheadHref="/"
>
  <Fragment slot="masthead-nav">
    <a href={`/${corporation.id}`} class={view === "summary" ? "is-active" : ""}>Summary</a>
    {speech && (
      <a href={`/${corporation.id}?view=goals`} class={view === "goals" ? "is-active" : ""}>Goals</a>
    )}
    <a href={`/${corporation.id}?view=budget`} class={view === "budget" ? "is-active" : ""}>Budget</a>
    <a href="/about">About</a>
  </Fragment>

  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: corporation.name.replace(" City Corporation", "") },
    ]}
  />


  {data ? (
    <>
      {view === "summary" && (
        <section class="fn-grid">
          {gridCards.map((c) => (
            <article class="fn-card" data-fn={c.code}>
              <div class="fn-card__head">
                <span class="fn-card__code">{c.code}</span>
                <h3 class="fn-card__name">{c.name}</h3>
              </div>

              <div class="fn-card__summary">
                <span class="fn-card__amount">{formatINR(c.amount)}</span>
                <span class="fn-card__meta">
                  {c.projectCount > 0
                    ? `${c.projectCount} ${c.projectCount === 1 ? "goal" : "goals"}`
                    : "No speech goals"}
                  {` · ${(c.share * 100).toFixed(1)}% of budget`}
                </span>
              </div>

              {c.highlights.length > 0 && (
                <ul class="fn-card__highlights">
                  {c.highlights.map((h) => (
                    <li class="fn-card__hl">
                      <a
                        href={`/${corporation.id}?view=goals#goals-fn-${c.code}`}
                        class="fn-card__hl-link"
                        title={h.description || h.name}
                      >
                        <span class="fn-card__hl-name">{h.name}</span>
                        {h.amount_lakhs != null && (
                          <span class="fn-card__hl-amt">{formatINR(h.amount_lakhs)}</span>
                        )}
                      </a>
                    </li>
                  ))}
                </ul>
              )}

              <div class="fn-card__foot">
                {c.projectCount > c.highlights.length ? (
                  <a
                    href={`/${corporation.id}?view=goals#goals-fn-${c.code}`}
                    class="fn-card__more"
                  >
                    {c.projectCount - c.highlights.length} more <i class="fa-solid fa-arrow-right"></i>
                  </a>
                ) : c.projectCount > 0 ? (
                  <a
                    href={`/${corporation.id}?view=goals#goals-fn-${c.code}`}
                    class="fn-card__more"
                  >
                    View all goals <i class="fa-solid fa-arrow-right"></i>
                  </a>
                ) : (
                  <a
                    href={`/${corporation.id}?view=budget#budget-fn-${c.code}`}
                    class="fn-card__more fn-card__more--muted"
                  >
                    View in budget <i class="fa-solid fa-arrow-right"></i>
                  </a>
                )}
              </div>
            </article>
          ))}
        </section>
      )}

      {view === "goals" && speech && (
        <section class="view-panel">
          <aside class="note-card">
            <i class="fa-solid fa-circle-info"></i>
            <div>
              <strong>From the Commissioner's Budget Speech, {new Date(speech.speech_date).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}.</strong>
              {` `}{speech.projects.length} goals announced by {speech.commissioner}, grouped here against the 12 budget functions using a keyword heuristic. Tagging is provisional and can be refined.
            </div>
          </aside>

          <div class="speech-grid">
            {FUNCTION_ORDER.map((fn) => {
              const items = projectsByFn.get(fn.code) ?? [];
              if (items.length === 0) return null;
              const withAmount = items.filter((p) => p.amount_lakhs != null);
              const totalLakhs = withAmount.reduce((sum, p) => sum + (p.amount_lakhs ?? 0), 0);
              return (
                <details class="speech-fn-block" id={`goals-fn-${fn.code}`} data-fn={fn.code} open>
                  <summary class="fn-summary">
                    <span class="fn-lead">
                      <i class="fa-solid fa-chevron-right chev"></i>
                      <span class="fn-code">{fn.code}</span>
                      <span class="fn-name">{fn.name}</span>
                    </span>
                    <span class="fn-meta">
                      <span class="pill pill-count">{items.length} {items.length === 1 ? "goal" : "goals"}</span>
                      {totalLakhs > 0 && <span class="fn-amount">{formatINR(totalLakhs)}</span>}
                    </span>
                  </summary>
                  <ul class="speech-list">
                    {items.map((p) => (
                      <li class="speech-item">
                        <div class="speech-item-main">
                          <span class="speech-item-name">{p.name}</span>
                          {p.description && p.description !== p.name && (
                            <span class="speech-item-desc">{p.description}</span>
                          )}
                          <span class="speech-item-foot">
                            <span class="speech-page">p.{p.page}</span>
                            <span class="speech-reason" title={p.tag_reason}>{p.tag_reason}</span>
                          </span>
                        </div>
                        <div class="speech-item-meta">
                          {p.amount_lakhs != null ? (
                            <span class="speech-amount">{formatINR(p.amount_lakhs)}</span>
                          ) : (
                            <span class="speech-amount speech-amount--none">no amount</span>
                          )}
                        </div>
                      </li>
                    ))}
                  </ul>
                </details>
              );
            })}
          </div>

          <p class="source-line">
            Source: Budget Speech {data.fiscal_year}, {corporation.name}, delivered by {speech.commissioner} on {new Date(speech.speech_date).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}. Function tags are provisional — assigned by keyword heuristic and open to refinement.
          </p>
        </section>
      )}

      {view === "budget" && (
        <section class="view-panel">
        <div class="toolbar">
          <div class="toolbar-left">
            <button type="button" class="tool-btn" data-action="expand-all">
              <i class="fa-solid fa-chevrons-down"></i> Expand all
            </button>
            <button type="button" class="tool-btn" data-action="collapse-all">
              <i class="fa-solid fa-chevrons-up"></i> Collapse all
            </button>
          </div>
          <div class="toolbar-right">
            <span class="legend">
              <span class="swatch swatch-up"></span> budget grew
            </span>
            <span class="legend">
              <span class="swatch swatch-down"></span> budget shrank
            </span>
            <span class="legend">
              <span class="swatch swatch-spill"></span> spillover
            </span>
          </div>
        </div>

        <aside class="note-card">
          <i class="fa-solid fa-circle-info"></i>
          <div>
            <strong>Extracted from the OpenCity.in budget PDF.</strong> Captured {formatINR(data.total_2026_27)} of a book total of {`\u20B9`}3,826 Cr ({(data.total_2026_27 / 382595 * 100).toFixed(1)}% coverage). The remaining {`\u20B9`}{Math.round((382595 - data.total_2026_27) / 100)} Cr sit in rows where codes span columns irregularly on a handful of pages.
          </div>
        </aside>

        <section class="tree">
          {data.functions.map((fn) => (
            <details class="fn-block" id={`budget-fn-${fn.code}`} data-fn={fn.code} open={fn.code === "05"}>
              <summary class="fn-summary">
                <span class="fn-lead">
                  <i class="fa-solid fa-chevron-right chev"></i>
                  <span class="fn-code">{fn.code}</span>
                  <span class="fn-name">{cleanName(fn.name)}</span>
                </span>
                <span class="fn-meta">
                  {fn.spillover > 0 && (
                    <span class="pill pill-spill">
                      <i class="fa-solid fa-clock-rotate-left"></i>
                      {formatINR(fn.spillover)}
                    </span>
                  )}
                  <span class={`pill pill-yoy ${yoyClass(fn.yoy_pct)}`}>{fmtYoY(fn.yoy_pct) || "—"}</span>
                  <span class="fn-amount">{formatINR(fn.total_2026_27)}</span>
                </span>
              </summary>
              <div class="sub-list">
                {fn.sub_categories.length === 0 && (
                  <p class="no-data">No line items captured for this function yet.</p>
                )}
                {fn.sub_categories.map((sub) => (
                  <details class="sub-block">
                    <summary class="sub-summary">
                      <span class="sub-lead">
                        <i class="fa-solid fa-chevron-right chev chev-sm"></i>
                        <span class="sub-name">{cleanName(sub.name)}</span>
                      </span>
                      <span class="sub-meta">
                        {sub.spillover > 0 && (
                          <span class="pill pill-spill pill-sm">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                            {formatINR(sub.spillover)}
                          </span>
                        )}
                        <span class={`pill pill-yoy pill-sm ${yoyClass(sub.yoy_pct)}`}>{fmtYoY(sub.yoy_pct) || "—"}</span>
                        <span class="sub-amount">{formatINR(sub.total_2026_27)}</span>
                      </span>
                    </summary>
                    <ul class="item-list">
                      {sub.items.map((it) => (
                        <li class="item">
                          <span class="item-main">
                            <span class="item-code">{it.code}</span>
                            <span class="item-name">{cleanName(it.name)}</span>
                          </span>
                          <span class="item-meta">
                            {(it.pending ?? 0) > 0 && (
                              <span class="pill pill-spill pill-xs">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                {formatINR(it.pending!)}
                              </span>
                            )}
                            <span class={`pill pill-yoy pill-xs ${yoyClass(it.yoy_pct)}`}>{fmtYoY(it.yoy_pct) || "—"}</span>
                            <span class="item-amount">{formatINR(it.total_2026_27)}</span>
                          </span>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            </details>
          ))}
        </section>

        <p class="source-line">
          Source: <a href="https://data.opencity.in/dataset/gba-corporation-budgets-2026-27" rel="noopener" target="_blank">Corporation Budget Book {data.fiscal_year}</a>, OpenCity.in. Amounts in Indian Rupees (Lakh below one Crore, Crore above).
        </p>
      </section>
      )}
    </>
  ) : (
    <div class="card mt-2">
      <p class="text-muted">Line-item budget data not available for this corporation.</p>
    </div>
  )}
</BaseLayout>

<script is:inline>
  document.addEventListener("click", (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;
    const btn = t.closest("[data-action]");
    if (!btn) return;
    const action = btn.getAttribute("data-action");
    const all = document.querySelectorAll("details.fn-block, details.sub-block");
    if (action === "expand-all") all.forEach((d) => (d.open = true));
    if (action === "collapse-all") all.forEach((d) => (d.open = false));
  });
</script>

<style>
  :root {
    --num-font: "Inter", ui-sans-serif, system-ui, sans-serif;
    --c-ink: #1a202c;
    --c-ink-soft: #4a5568;
    --c-rule: #e2e8f0;
    --c-rule-soft: #edf2f7;
    --c-good: #137752;
    --c-good-bg: #e7f5ee;
    --c-bad: #9b2c2c;
    --c-bad-bg: #fdeceb;
    --c-neutral: #718096;
    --c-neutral-bg: #edf2f7;
    --c-spill: #9a6700;
    --c-spill-bg: #fff4cc;
  }

  /* Per-function color palette — same colors used on Summary cards and
     accordion headers in Goals/Budget so the 12 functions stay visually
     consistent across views. */
  [data-fn="01"] { --fn-c: #475569; --fn-bg: #f1f5f9; }  /* Council */
  [data-fn="02"] { --fn-c: #52525b; --fn-bg: #f4f4f5; }  /* General Admin */
  [data-fn="03"] { --fn-c: #b45309; --fn-bg: #fef3c7; }  /* Revenue */
  [data-fn="04"] { --fn-c: #c2410c; --fn-bg: #ffedd5; }  /* Town Planning */
  [data-fn="05"] { --fn-c: #1d4ed8; --fn-bg: #dbeafe; }  /* Public Works */
  [data-fn="06"] { --fn-c: #0f766e; --fn-bg: #ccfbf1; }  /* SWM */
  [data-fn="07"] { --fn-c: #9d174d; --fn-bg: #fce7f3; }  /* Public Health-General */
  [data-fn="08"] { --fn-c: #b91c1c; --fn-bg: #fee2e2; }  /* Public Health-Medical */
  [data-fn="09"] { --fn-c: #4d7c0f; --fn-bg: #ecfccb; }  /* Horticulture */
  [data-fn="10"] { --fn-c: #166534; --fn-bg: #dcfce7; }  /* Urban Forestry */
  [data-fn="11"] { --fn-c: #6d28d9; --fn-bg: #ede9fe; }  /* Public Education */
  [data-fn="12"] { --fn-c: #4338ca; --fn-bg: #e0e7ff; }  /* Social Welfare */

  .page-head {
    text-align: left;
    margin: 2rem 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--c-rule);
  }
  .page-head .eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-soft);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .page-head h1 {
    text-align: left;
    font-size: clamp(1.75rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--c-ink);
    margin: 0;
  }
  .page-head .lede {
    margin: 0.75rem 0 0;
    max-width: 68ch;
    color: var(--c-ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  /* Topline grid */
  .topline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--c-card);
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
  .tl-cell {
    padding: 1.1rem 1.25rem;
    border-right: 1px solid var(--c-rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #fff;
  }
  .tl-cell:last-child { border-right: none; }
  .tl-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-soft);
    font-weight: 600;
  }
  .tl-value {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .tl-value--muted { color: var(--c-ink-soft); font-weight: 600; }
  .tl-value--accent { color: var(--c-spill); }
  .tl-value.yoy-up { color: var(--c-good); }
  .tl-value.yoy-down { color: var(--c-bad); }
  .tl-value.yoy-zero, .tl-value.yoy-none { color: var(--c-neutral); }
  .tl-sub {
    font-size: 0.74rem;
    color: var(--c-neutral);
  }

  /* Toolbar */
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.25rem 0 0.75rem;
  }
  .toolbar-left { display: flex; gap: 0.5rem; }
  .toolbar-right {
    display: flex;
    gap: 0.9rem;
    font-size: 0.78rem;
    color: var(--c-ink-soft);
  }
  .legend { display: inline-flex; align-items: center; gap: 0.35rem; }
  .swatch {
    width: 10px; height: 10px; border-radius: 2px; display: inline-block;
  }
  .swatch-up { background: var(--c-good); }
  .swatch-down { background: var(--c-bad); }
  .swatch-spill { background: var(--c-spill); }

  .tool-btn {
    font-family: var(--num-font);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 0.85rem;
    background: #fff;
    border: 1px solid var(--c-rule);
    border-radius: 6px;
    color: var(--c-ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.15s ease;
  }
  .tool-btn:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: #f7fafc;
  }
  .tool-btn i { font-size: 0.75rem; }

  /* Note card */
  .note-card {
    display: flex;
    gap: 0.65rem;
    padding: 0.8rem 1rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid var(--c-accent);
    border-radius: 6px;
    color: #78350f;
    font-size: 0.86rem;
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .note-card i { color: var(--c-spill); margin-top: 0.2rem; }

  /* Tree */
  .tree {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fn-block {
    background: #fff;
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .fn-block[open] {
    border-color: var(--c-primary);
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }

  summary { list-style: none; cursor: pointer; }
  summary::-webkit-details-marker { display: none; }

  .fn-summary {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
  }
  .fn-summary:hover { background: #f8fafc; }
  .fn-lead {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }
  .chev {
    color: var(--c-neutral);
    transition: transform 0.2s ease;
    font-size: 0.8rem;
    width: 0.9rem;
    flex-shrink: 0;
  }
  details[open] > summary .chev { transform: rotate(90deg); }
  .chev-sm { font-size: 0.7rem; color: var(--c-neutral); }

  .fn-code {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--c-neutral);
    background: var(--c-rule-soft);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.04em;
  }
  .fn-name {
    font-size: 1.02rem;
