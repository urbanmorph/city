---
import {
  loadCorporation,
  loadCategories,
  loadMergedItems,
} from "../../../lib/data-loader";
import { editorForToken } from "../../../lib/supabase";

export const prerender = false;

const { corporation: corpId } = Astro.params;
const VALID = new Set(["south", "central", "east", "west", "north"]);
if (!corpId || !VALID.has(corpId)) return Astro.redirect("/404");

const urlToken = Astro.url.searchParams.get("token");
const cookieToken = Astro.cookies.get("review_token")?.value ?? null;
const token = urlToken ?? cookieToken;
const editor = editorForToken(token);

if (!editor) {
  return new Response("Forbidden — valid ?token= required", {
    status: 403, headers: { "content-type": "text/plain" },
  });
}

if (urlToken && urlToken !== cookieToken) {
  Astro.cookies.set("review_token", urlToken, {
    path: "/", httpOnly: false, sameSite: "lax", maxAge: 60 * 60 * 24 * 30,
  });
}

const corp = loadCorporation("bengaluru", corpId);
if (!corp) return Astro.redirect("/404");

const categories = loadCategories("bengaluru", corpId);
const items = await loadMergedItems("bengaluru", corpId);

// Flat list in speech order (by page, then id). No grouping — users reassign
// and the row stays put instead of jumping around.
const orderedItems = [...items].sort((a, b) => {
  const ap = a.page || 9999, bp = b.page || 9999;
  if (ap !== bp) return ap - bp;
  return a.id.localeCompare(b.id);
});

const overrideCount = items.filter((it) => it.has_override).length;
const totalCount = items.length;

function fmtAmount(lakhs: number | null | undefined): string {
  if (lakhs == null) return "no amount";
  if (lakhs >= 100) return `₹${(lakhs / 100).toFixed(2)} Cr`;
  return `₹${lakhs.toFixed(2)} L`;
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Review speech items — {corp.name}</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex,nofollow" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
  <style is:global>
    :root {
      --c-primary: #3F5F7A;
      --c-ink: #1a202c;
      --c-ink-soft: #4a5568;
      --c-rule: #e2e8f0;
      --c-rule-soft: #edf2f7;
      --c-neutral: #718096;
      --c-good: #137752;
      --c-good-bg: #e7f5ee;
      --c-bg: #f9fafb;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Inter", system-ui, -apple-system, sans-serif;
      color: var(--c-ink); background: var(--c-bg); line-height: 1.5;
    }
    .masthead { background: var(--c-primary); color: #fff; padding: 1.1rem 0; }
    .container { max-width: 1080px; margin: 0 auto; padding: 0 1rem; }
    .masthead h1 { font-size: 1.35rem; font-weight: 800; letter-spacing: -0.01em; }
    .masthead p { font-size: 0.84rem; color: rgba(255,255,255,0.78); margin-top: 0.15rem; }

    [data-cat="administration"], [data-cat="finance-and-accounts"], [data-cat="public-relations"]      { --cat-c: #52525b; --cat-bg: #f4f4f5; }
    [data-cat="revenue"], [data-cat="advertisement"], [data-cat="markets"], [data-cat="properties"], [data-cat="assets"]                { --cat-c: #b45309; --cat-bg: #fef3c7; }
    [data-cat="land-acquisition"], [data-cat="urban-planning"]        { --cat-c: #c2410c; --cat-bg: #ffedd5; }
    [data-cat="public-works"], [data-cat="lakes-division"], [data-cat="storm-water-drains"]    { --cat-c: #1d4ed8; --cat-bg: #dbeafe; }
    [data-cat="education"]             { --cat-c: #6d28d9; --cat-bg: #ede9fe; }
    [data-cat="forestry"], [data-cat="urban-forestry"]        { --cat-c: #166534; --cat-bg: #dcfce7; }
    [data-cat="horticulture"]          { --cat-c: #4d7c0f; --cat-bg: #ecfccb; }
    [data-cat="health"], [data-cat="health-department-clinical"] { --cat-c: #9d174d; --cat-bg: #fce7f3; }
    [data-cat="sanitation"]            { --cat-c: #0f766e; --cat-bg: #ccfbf1; }
    [data-cat="animal-husbandry"]      { --cat-c: #b91c1c; --cat-bg: #fee2e2; }
    [data-cat="welfare"]               { --cat-c: #4338ca; --cat-bg: #e0e7ff; }

    .sub-bar {
      background: #fff; border-bottom: 1px solid var(--c-rule);
      padding: 0.65rem 0; position: sticky; top: 0; z-index: 10;
    }
    .sub-row {
      display: flex; align-items: center; gap: 0.7rem;
      flex-wrap: wrap; justify-content: space-between;
      font-size: 0.85rem; color: var(--c-ink-soft);
    }
    .progress strong { color: var(--c-ink); font-weight: 700; }
    .progress .bar {
      display: inline-block; width: 120px; height: 5px;
      background: var(--c-rule-soft); border-radius: 3px;
      vertical-align: middle; margin: 0 0.45rem; overflow: hidden;
    }
    .progress .bar > span { display: block; height: 100%; background: var(--c-good); }
    .sub-row input[type=text] {
      font: inherit; padding: 0.35rem 0.55rem;
      border: 1px solid var(--c-rule); border-radius: 4px;
      background: #fff; color: var(--c-ink); flex: 1 1 200px; min-width: 180px;
    }
    .editor-info { font-size: 0.78rem; color: var(--c-neutral); }

    .add-bar { display: flex; gap: 0.5rem; padding: 0.8rem 0 0.1rem; }
    .btn-primary {
      font: inherit; font-size: 0.85rem; font-weight: 600;
      padding: 0.4rem 0.9rem; border-radius: 5px;
      background: var(--c-primary); color: #fff; border: 0; cursor: pointer;
    }
    .btn-primary:hover { background: #2f4a60; }
    .add-form {
      display: none; background: #fff; border: 1px solid var(--c-rule);
      border-radius: 6px; padding: 0.9rem; margin: 0.6rem 0;
      flex-direction: column; gap: 0.55rem;
    }
    .add-form.open { display: flex; }
    .add-form label { font-size: 0.78rem; font-weight: 600; color: var(--c-ink-soft); display: block; }
    .add-form input, .add-form textarea, .add-form select {
      font: inherit; width: 100%; padding: 0.4rem 0.55rem;
      border: 1px solid var(--c-rule); border-radius: 4px;
      background: #fff; color: var(--c-ink); margin-top: 0.15rem;
    }
    .add-form textarea { min-height: 60px; resize: vertical; }
    .add-form-row { display: grid; grid-template-columns: 1fr 140px 100px; gap: 0.5rem; }
    .add-form-actions { display: flex; gap: 0.5rem; justify-content: flex-end; }
    .add-form-cancel {
      font: inherit; font-size: 0.82rem;
      padding: 0.4rem 0.85rem; border-radius: 5px;
      background: #fff; color: var(--c-ink-soft);
      border: 1px solid var(--c-rule); cursor: pointer;
    }

    main { padding: 0.2rem 0 4rem; }
    .flat-list {
      background: #fff; border: 1px solid var(--c-rule); border-radius: 6px;
      overflow: hidden;
    }
    .item {
      display: grid; grid-template-columns: 1fr 240px;
      gap: 0.45rem 1rem;
      padding: 0.75rem 0.9rem 0.75rem 1rem;
      border-bottom: 1px solid var(--c-rule-soft);
      border-left: 3px solid var(--cat-c, transparent);
      padding-left: calc(1rem - 3px);
      transition: border-left-color 0.15s, background 0.15s;
    }
    .item:last-child { border-bottom: 0; }
    .item:hover { background: #fcfcfd; }
    .item.manual { background: #f5f3ff; border-left: 3px solid #7c3aed; }

    .manual-badge {
      display: inline-block; background: #7c3aed; color: #fff;
      font-size: 0.62rem; font-weight: 700; letter-spacing: 0.04em;
      padding: 0.05rem 0.35rem; border-radius: 3px; text-transform: uppercase;
      margin-right: 0.3rem; vertical-align: middle;
    }

    .item-head { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
    .item-name { font-size: 0.92rem; font-weight: 600; color: var(--c-ink); }
    .item-meta {
      font-size: 0.74rem; color: var(--c-neutral);
      font-variant-numeric: tabular-nums;
      display: inline-flex; gap: 0.5rem; align-items: center; margin-left: auto;
    }
    .page-pill { background: var(--c-rule-soft); color: var(--c-ink-soft); padding: 0.04rem 0.4rem; border-radius: 3px; font-weight: 600; }
    .amt { color: var(--c-ink); font-weight: 700; }
    .verbatim { font-size: 0.8rem; color: var(--c-ink-soft); font-style: italic; line-height: 1.45; }

    .cat-cell { display: flex; flex-direction: column; gap: 0.28rem; align-items: flex-start; }
    .cat-select {
      font: inherit; font-size: 0.82rem;
      padding: 0.3rem 0.55rem; width: 100%;
      border: 1px solid var(--c-rule); border-radius: 5px;
      background: #fff; color: var(--c-ink);
    }
    .cat-select:focus { outline: 2px solid var(--cat-c, var(--c-primary)); outline-offset: -1px; border-color: transparent; }
    .cat-select[data-touched="1"] {
      font-weight: 600; background: var(--cat-bg, #fff); color: var(--cat-c, var(--c-ink));
      border-color: var(--cat-c, var(--c-rule));
    }
    .cat-select[data-touched="0"] { color: var(--c-ink-soft); }
    .auto-hint { font-size: 0.68rem; color: var(--c-neutral); font-style: italic; }
    .auto-hint.touched { color: var(--c-good); font-style: normal; }
    .save-state { font-size: 0.68rem; color: var(--c-neutral); font-style: italic; }
    .save-state.saved { color: var(--c-good); }
    .save-state.error { color: #9b2c2c; }

    .delete-manual {
      font: inherit; font-size: 0.7rem;
      background: none; border: 0; color: #9b2c2c;
      cursor: pointer; padding: 0; margin-top: 0.2rem;
      text-decoration: underline;
    }

    .hint {
      color: var(--c-neutral); font-size: 0.78rem;
      padding: 0.9rem 0; border-top: 1px solid var(--c-rule); margin-top: 1.2rem;
    }

    @media (max-width: 720px) {
      .masthead h1 { font-size: 1.15rem; }
      .container { padding: 0 0.75rem; }
      .item { grid-template-columns: 1fr; padding: 0.7rem 0.75rem; }
      .item.manual { padding-left: calc(0.75rem - 3px); }
      .item-meta { margin-left: 0; font-size: 0.7rem; }
      .cat-cell { width: 100%; }
      .sub-row { font-size: 0.8rem; gap: 0.5rem; }
      .progress .bar { width: 90px; }
      .add-form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body data-corp-id={corpId}>

<header class="masthead">
  <div class="container">
    <h1>{corp.name} · Review speech items</h1>
    <p>Items auto-tagged to the section they appear under in the speech. Change the category to move an item.</p>
  </div>
</header>

<div class="sub-bar">
  <div class="container">
    <div class="sub-row">
      <div class="progress">
        <strong><span id="touched-count">{overrideCount}</span> / {totalCount}</strong> edited
        <span class="bar"><span id="touched-bar" style={`width: ${totalCount ? Math.round(overrideCount * 100 / totalCount) : 0}%`}></span></span>
      </div>
      <input type="text" id="search" placeholder="Search name, description, verbatim…" />
      <div class="editor-info">Signed in as <strong>{editor}</strong></div>
    </div>
  </div>
</div>

<main class="container">

<div class="add-bar">
  <button class="btn-primary" type="button" id="toggle-add-form">+ Add project</button>
</div>

<form class="add-form" id="add-form">
  <div>
    <label for="af-name">Project name</label>
    <input type="text" id="af-name" required minlength="3" placeholder="e.g. New flyover at Koramangala junction" />
  </div>
  <div>
    <label for="af-verbatim">Verbatim / source (optional)</label>
    <textarea id="af-verbatim" placeholder="Quote from document or note on source"></textarea>
  </div>
  <div class="add-form-row">
    <div>
      <label for="af-category">Category</label>
      <select id="af-category" required>
        {categories.map((c) => <option value={c.code}>{c.title}</option>)}
      </select>
    </div>
    <div>
      <label for="af-amount">Amount (Cr)</label>
      <input type="number" id="af-amount" step="0.01" placeholder="e.g. 12.50" />
    </div>
    <div>
      <label for="af-page">Page</label>
      <input type="number" id="af-page" step="1" placeholder="optional" />
    </div>
  </div>
  <div class="add-form-actions">
    <button type="button" class="add-form-cancel" id="af-cancel">Cancel</button>
    <button type="submit" class="btn-primary">Add project</button>
  </div>
</form>

<div class="flat-list">
  {orderedItems.map((r) => (
    <div class={`item${r.source === "manual" ? " manual" : ""}`} data-cat={r.effective_category}>
      <div>
        <div class="item-head">
          {r.source === "manual" && <span class="manual-badge">manual</span>}
          <span class="item-name">{r.name}</span>
          <span class="item-meta">
            {r.page > 0 && <span class="page-pill">p.{r.page}</span>}
            <span class="amt">{fmtAmount(r.amount_lakhs)}</span>
          </span>
        </div>
        {r.verbatim_quote && <p class="verbatim">"{r.verbatim_quote}"</p>}
        {r.source === "manual" && (
          <button class="delete-manual" type="button" data-delete-manual={r.id}>delete project</button>
        )}
      </div>
      <div class="cat-cell">
        <select
          class="cat-select"
          data-item-id={r.id}
          data-touched={r.has_override ? "1" : "0"}
          data-cat={r.effective_category}
        >
          {categories.map((c) => (
            <option value={c.code} selected={c.code === r.effective_category}>{c.title}</option>
          ))}
        </select>
        <span class={`auto-hint${r.has_override ? " touched" : ""}`}>
          {r.has_override ? "reviewed" : "auto-tagged from speech"}
        </span>
        <span class="save-state"></span>
      </div>
    </div>
  ))}
</div>

<p class="hint">Change a category dropdown to move the item. Edits auto-save · items show up on the new category card immediately.</p>

</main>

<script define:vars={{ corpId }}>
  const CORP_ID = corpId;
  function byId(id) { return document.getElementById(id); }

  function updateProgress() {
    const cells = document.querySelectorAll(".cat-select");
    let touched = 0, total = cells.length;
    cells.forEach((c) => { if (c.dataset.touched === "1") touched++; });
    byId("touched-count").textContent = touched;
    byId("touched-bar").style.width = total ? Math.round((touched / total) * 100) + "%" : "0%";
  }

  async function saveCategory(select) {
    const itemId = select.dataset.itemId;
    const category = select.value;
    const cell = select.closest(".cat-cell");
    const state = cell.querySelector(".save-state");
    const hint = cell.querySelector(".auto-hint");
    state.textContent = "saving…";
    state.className = "save-state";
    try {
      const res = await fetch("/api/review/tag", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ corpId: CORP_ID, itemId, category }),
      });
      if (!res.ok) throw new Error(await res.text());
      select.dataset.touched = "1";
      select.dataset.cat = category;
      const row = select.closest(".item");
      if (row) row.dataset.cat = category;
      hint.textContent = "reviewed";
      hint.className = "auto-hint touched";
      state.textContent = "saved";
      state.className = "save-state saved";
      setTimeout(() => { state.textContent = ""; }, 1500);
      updateProgress();
    } catch (e) {
      state.textContent = "error";
      state.className = "save-state error";
      console.error(e);
    }
  }

  document.addEventListener("change", (e) => {
    if (e.target.matches(".cat-select")) saveCategory(e.target);
  });

  byId("toggle-add-form").addEventListener("click", () => byId("add-form").classList.toggle("open"));
  byId("af-cancel").addEventListener("click", () => byId("add-form").classList.remove("open"));
  byId("add-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const name = byId("af-name").value.trim();
    if (name.length < 3) return;
    const amountCr = parseFloat(byId("af-amount").value);
    const payload = {
      corpId: CORP_ID, name,
      verbatim_quote: byId("af-verbatim").value,
      category: byId("af-category").value,
      amount_lakhs: isFinite(amountCr) ? amountCr * 100 : null,
      page: byId("af-page").value ? parseInt(byId("af-page").value, 10) : null,
    };
    try {
      const res = await fetch("/api/review/manual-item", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(await res.text());
      location.reload();
    } catch (err) { alert("Could not add project: " + err.message); }
  });

  document.addEventListener("click", async (e) => {
    const btn = e.target.closest("[data-delete-manual]");
    if (!btn) return;
    if (!confirm("Delete this manual project?")) return;
    const itemId = btn.dataset.deleteManual;
    const res = await fetch("/api/review/manual-item", {
      method: "DELETE", headers: { "content-type": "application/json" },
      body: JSON.stringify({ corpId: CORP_ID, itemId }),
    });
    if (res.ok) location.reload();
    else alert("Delete failed");
  });

  byId("search").addEventListener("input", (e) => {
    const q = e.target.value.toLowerCase().trim();
    document.querySelectorAll(".item").forEach((item) => {
      const hay = item.textContent.toLowerCase();
      item.style.display = !q || hay.includes(q) ? "" : "none";
    });
  });
</script>

</body>
</html>
