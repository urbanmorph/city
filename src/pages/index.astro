---
import BaseLayout from "../layouts/BaseLayout.astro";
import CorporationCard from "../components/CorporationCard.astro";
import { loadCities, loadCorporations, loadBudget, loadLineItemBudget, loadSpeechProjects } from "../lib/data-loader";
import { formatINR } from "../lib/format";

const cities = loadCities();
const city = cities[0]; // Bengaluru — only city with data
const corporations = loadCorporations(city.id);

type CardData = {
  corporation: (typeof corporations)[number];
  totalBudgetLakhs: number;
  functionsTracked: number;
  goalsTracked: number;
  dataStatus: "full" | "partial" | "none";
};

const cardData: CardData[] = corporations.map((corp) => {
  const lineItems = loadLineItemBudget(city.id, corp.id);
  const speech = loadSpeechProjects(city.id, corp.id);
  const goalsTracked = speech?.projects.length ?? 0;

  if (lineItems) {
    return {
      corporation: corp,
      totalBudgetLakhs: lineItems.total_2026_27,
      functionsTracked: lineItems.functions.filter((f) => f.total_2026_27 > 0).length,
      goalsTracked,
      dataStatus: corp.id === "south" ? "partial" : "full",
    };
  }
  const budget = loadBudget(city.id, corp.id, city.budget_year);
  return {
    corporation: corp,
    totalBudgetLakhs: budget?.summary.total_expenditure ?? 0,
    functionsTracked: 0,
    goalsTracked,
    dataStatus: "none",
  };
});

const totalBudgetLakhs = cardData.reduce((sum, c) => sum + c.totalBudgetLakhs, 0);
const totalWards = corporations.reduce((sum, c) => sum + c.wards, 0);
---

<BaseLayout
  title="City Corporations"
  description={`Public finances and program of works across ${corporations.length} city corporations.`}
  mastheadTitle="City Corporations"
  mastheadSubtitle={`Public Finances and Program of Works, fiscal year ${city.budget_year}`}
>
  <Fragment slot="masthead-nav">
    <a href="/about">About</a>
  </Fragment>
  <section class="topline">
    <div class="tl-cell">
      <span class="tl-label">Total Budget</span>
      <span class="tl-value">{formatINR(totalBudgetLakhs)}</span>
      <span class="tl-sub">{city.budget_year} across {corporations.length} corporations</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Corporations</span>
      <span class="tl-value">{corporations.length}</span>
      <span class="tl-sub">Municipal corporations</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Wards</span>
      <span class="tl-value">{totalWards}</span>
      <span class="tl-sub">Elected representatives</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Fiscal Year</span>
      <span class="tl-value">{city.budget_year}</span>
      <span class="tl-sub">Budget Estimate</span>
    </div>
  </section>

  <section class="corps-section">
    <div class="card-grid">
      {cardData.map((c) => (
        <CorporationCard
          corporation={c.corporation}
          totalBudgetLakhs={c.totalBudgetLakhs}
          functionsTracked={c.functionsTracked}
          goalsTracked={c.goalsTracked}
          dataStatus={c.dataStatus}
        />
      ))}
    </div>
  </section>

  <p class="source-line">
    Amounts in Indian Rupees (Lakh below one Crore, Crore above). Data from the official budget books published by the corporations.
  </p>
</BaseLayout>

<style>
  :root {
    --num-font: "Inter", ui-sans-serif, system-ui, sans-serif;
    --c-ink: #1a202c;
    --c-ink-soft: #4a5568;
    --c-rule: #e2e8f0;
    --c-rule-soft: #edf2f7;
    --c-good: #137752;
    --c-good-bg: #e7f5ee;
    --c-bad: #9b2c2c;
    --c-bad-bg: #fdeceb;
    --c-neutral: #718096;
    --c-neutral-bg: #edf2f7;
    --c-spill: #9a6700;
    --c-spill-bg: #fff4cc;
  }

  .page-head {
    text-align: left;
    margin: 2rem 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--c-rule);
  }
  .page-head .eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-soft);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .page-head h1 {
    text-align: left;
    font-size: clamp(1.75rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--c-ink);
    margin: 0;
  }
  .page-head .lede {
    margin: 0.75rem 0 0;
    max-width: 68ch;
    color: var(--c-ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  /* Topline grid */
  .topline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--c-card);
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
  .tl-cell {
    padding: 1.1rem 1.25rem;
    border-right: 1px solid var(--c-rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #fff;
  }
  .tl-cell:last-child { border-right: none; }
  .tl-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-soft);
    font-weight: 600;
  }
  .tl-value {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .tl-sub {
    font-size: 0.74rem;
    color: var(--c-neutral);
  }

  /* Corps section */
  .corps-section {
    margin-top: 2rem;
  }
  .section-head {
    margin-bottom: 1rem;
  }
  .section-head h2 {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .section-sub {
    margin: 0.3rem 0 0;
    font-size: 0.88rem;
    color: var(--c-ink-soft);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .source-line {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--c-rule);
    font-size: 0.82rem;
    color: var(--c-ink-soft);
  }
  .source-line a { color: var(--c-primary); }

  @media (max-width: 960px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 720px) {
    .topline { grid-template-columns: repeat(2, 1fr); }
    .tl-cell { border-right: none; border-bottom: 1px solid var(--c-rule); }
    .tl-cell:nth-child(odd) { border-right: 1px solid var(--c-rule); }
    .tl-cell:last-child, .tl-cell:nth-last-child(2) { border-bottom: none; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
