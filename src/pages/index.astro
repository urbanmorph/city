---
import BaseLayout from "../layouts/BaseLayout.astro";
import CorporationCard from "../components/CorporationCard.astro";
import { loadCities, loadCorporations, loadBudget, loadGrievances, loadFunctionMapping } from "../lib/data-loader";
import { computeAllHealth, countByStatus } from "../lib/health-score";
import { formatINR, formatNumber } from "../lib/format";

const cities = loadCities();

const cityData = cities.map((city) => {
  const corporations = loadCorporations(city.id);
  const mapping = loadFunctionMapping(city.id);

  const corpStats = corporations.map((corp) => {
    const budget = loadBudget(city.id, corp.id, city.budget_year);
    const grievances = loadGrievances(city.id, corp.id);

    let stressedCount = 0;
    let totalBudget = 0;
    let totalComplaints = 0;

    if (budget && grievances) {
      const healthList = computeAllHealth(corp.id, budget, grievances, mapping);
      const counts = countByStatus(healthList);
      stressedCount = counts.stressed + counts.critical + counts.unfunded;
      totalBudget = budget.summary.total_expenditure;
      totalComplaints = grievances.total_complaints;
    }

    return {
      corporation: corp,
      stressedCount,
      totalBudget: formatINR(totalBudget),
      totalComplaints: formatNumber(totalComplaints),
    };
  });

  return { city, corporations, mapping, corpStats };
});
---

<BaseLayout title="City Portal">
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <h1>Governance Accountability for Indian Cities</h1>
    <p class="hero__sub">From mandate to money to outcomes &mdash; the full story of how your city works</p>
  </section>

  <!-- ── 6-Layer Narrative ────────────────────────────────── -->
  <section class="narrative-flow">
    <h2 class="narrative-flow__title">How we measure governance</h2>
    <p class="text-sm text-muted">For each civic function, we trace the complete chain from law to lived reality.</p>

    <div class="flow-steps">
      <div class="flow-step">
        <span class="flow-step__num">1</span>
        <div class="flow-step__content">
          <strong>The Mandate</strong>
          <span>What does the law require?</span>
          <span class="flow-step__source">GBA Act, Schedule I</span>
        </div>
      </div>
      <div class="flow-arrow-h" aria-hidden="true">&rarr;</div>
      <div class="flow-step">
        <span class="flow-step__num">2</span>
        <div class="flow-step__content">
          <strong>The Money</strong>
          <span>How much is allocated?</span>
          <span class="flow-step__source">Budget books 2026-27</span>
        </div>
      </div>
      <div class="flow-arrow-h" aria-hidden="true">&rarr;</div>
      <div class="flow-step">
        <span class="flow-step__num">3</span>
        <div class="flow-step__content">
          <strong>The People</strong>
          <span>Are there enough staff?</span>
          <span class="flow-step__source">ASICS 2023</span>
        </div>
      </div>
      <div class="flow-arrow-h" aria-hidden="true">&rarr;</div>
      <div class="flow-step">
        <span class="flow-step__num">4</span>
        <div class="flow-step__content">
          <strong>The Reality</strong>
          <span>What do citizens experience?</span>
          <span class="flow-step__source">BBMP Sahaaya, 766K complaints</span>
        </div>
      </div>
      <div class="flow-arrow-h" aria-hidden="true">&rarr;</div>
      <div class="flow-step">
        <span class="flow-step__num">5</span>
        <div class="flow-step__content">
          <strong>Who's Responsible</strong>
          <span>Your ward, your rep</span>
          <span class="flow-step__source">kaun.city</span>
        </div>
      </div>
      <div class="flow-arrow-h" aria-hidden="true">&rarr;</div>
      <div class="flow-step flow-step--verdict">
        <span class="flow-step__num">6</span>
        <div class="flow-step__content">
          <strong>The Verdict</strong>
          <span>Is this function healthy?</span>
          <span class="flow-step__source">Health score</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Cities ───────────────────────────────────────────── -->
  {cityData.map(({ city, mapping, corpStats }) => (
    <section class="city-section">
      <div class="city-header">
        <h2>
          <a href={`/${city.id}`}>{city.name}</a>
        </h2>
        <p class="text-local">{city.name_local}</p>
        <p class="text-sm text-muted">{city.authority} &mdash; {city.act.short_name} ({city.act.year})</p>
      </div>

      <dl class="city-meta">
        <div>
          <dt>Functions</dt>
          <dd>{mapping.length}</dd>
        </div>
        <div>
          <dt>Corporations</dt>
          <dd>{city.corporation_count}</dd>
        </div>
        <div>
          <dt>Budget Year</dt>
          <dd>{city.budget_year}</dd>
        </div>
        <div>
          <dt>Staff / Lakh</dt>
          <dd>317</dd>
        </div>
        <div>
          <dt>Vacancy</dt>
          <dd>52%</dd>
        </div>
      </dl>

      <div class="card-grid mt-1">
        {corpStats.map(({ corporation, stressedCount, totalBudget, totalComplaints }) => (
          <CorporationCard
            cityId={city.id}
            corporation={corporation}
            stressedCount={stressedCount}
            totalBudget={totalBudget}
            totalComplaints={totalComplaints}
          />
        ))}
      </div>

      <nav class="city-links mt-1">
        <a href={`/${city.id}/act`}>{city.act.short_name} &mdash; 26 chapters, 361 sections</a>
        <span class="city-links__sep">&middot;</span>
        <a href={`/${city.id}/compare`}>Compare corporations</a>
      </nav>
    </section>
  ))}
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 2.5rem 0 1rem;
  }
  .hero h1 {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--c-primary);
    letter-spacing: -0.02em;
  }
  .hero__sub {
    font-size: 1rem;
    color: var(--c-text-muted);
    margin-top: 0.4rem;
  }

  /* ── 6-Layer Flow ───────────────────────────────────────── */
  .narrative-flow {
    margin: 1.5rem 0 2rem;
    padding: 1.25rem;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .narrative-flow__title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--c-primary);
    margin-bottom: 0.25rem;
  }
  .flow-steps {
    display: flex;
    align-items: stretch;
    gap: 0;
    margin-top: 1rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .flow-step {
    flex: 1;
    min-width: 120px;
    display: flex;
    gap: 0.5rem;
    padding: 0.75rem;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .flow-step--verdict {
    background: #f0f4f8;
    border-color: var(--c-primary);
  }
  .flow-step__num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--c-primary);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .flow-step--verdict .flow-step__num {
    background: var(--c-accent);
    color: var(--c-text);
  }
  .flow-step__content {
    display: flex;
    flex-direction: column;
    font-size: 0.82rem;
    line-height: 1.4;
  }
  .flow-step__content strong {
    font-size: 0.85rem;
    color: var(--c-text);
  }
  .flow-step__content span {
    color: var(--c-text-muted);
  }
  .flow-step__source {
    font-size: 0.7rem;
    font-style: italic;
    margin-top: 0.2rem;
  }
  .flow-arrow-h {
    display: flex;
    align-items: center;
    padding: 0 0.25rem;
    color: var(--c-text-muted);
    font-size: 1rem;
    flex-shrink: 0;
  }

  /* ── City Section ───────────────────────────────────────── */
  .city-section {
    margin-bottom: 2rem;
  }
  .city-header h2 {
    font-size: 1.35rem;
    font-weight: 700;
  }
  .city-header h2 a {
    color: var(--c-primary);
  }
  .city-header h2 a:hover {
    text-decoration: underline;
  }
  .city-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-top: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .city-meta dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }
  .city-meta dd {
    font-size: 0.95rem;
    font-weight: 600;
  }
  .city-links {
    font-size: 0.88rem;
  }
  .city-links a {
    color: var(--c-primary);
    font-weight: 500;
  }
  .city-links__sep {
    margin: 0 0.5rem;
    color: var(--c-text-muted);
  }

  @media (max-width: 640px) {
    .hero h1 { font-size: 1.3rem; }
    .city-meta { gap: 1rem; }
    .flow-steps { flex-wrap: wrap; gap: 0.5rem; }
    .flow-arrow-h { display: none; }
    .flow-step { min-width: calc(50% - 0.25rem); }
  }
</style>
