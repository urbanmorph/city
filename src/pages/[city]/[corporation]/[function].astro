---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import HealthBadge from "../../../components/HealthBadge.astro";
import { loadCity, loadCorporation, loadFunctionMapping, loadBudget, loadGrievances } from "../../../lib/data-loader";
import { computeFunctionHealth } from "../../../lib/health-score";
import { formatINR, formatPercent, formatGrowth, formatNumber } from "../../../lib/format";
import type { HealthStatus } from "../../../lib/types";

const { city: cityId, corporation: corpId, function: fnSlug } = Astro.params;

const cityData = loadCity(cityId!);
if (!cityData) return Astro.redirect("/404");

const corpData = loadCorporation(cityId!, corpId!);
if (!corpData) return Astro.redirect("/404");

const mapping = loadFunctionMapping(cityId!);
const fnDef = mapping.find((f) => f.id === fnSlug);
if (!fnDef) {
  return new Response(null, { status: 404, statusText: "Function not found" });
}

const budget = loadBudget(cityId!, corpId!);
const grievances = loadGrievances(cityId!, corpId!);

if (!budget || !grievances) {
  return new Response(null, { status: 404, statusText: "Data not available" });
}

const health = computeFunctionHealth(fnDef.id, corpId!, budget, grievances, mapping);

const budgetEntry = budget.by_function[fnDef.id];
const grievanceEntry = grievances.by_function[fnDef.id];

const budgetAmount = budgetEntry?.amount ?? 0;
const budgetShare = budgetEntry?.share ?? 0;
const yoyGrowth = budgetEntry?.yoy_growth ?? 0;
const complaintCount = grievanceEntry?.count ?? 0;
const complaintShare = grievanceEntry?.share ?? 0;
const resolutionRate = grievanceEntry?.resolution_rate ?? 0;

// Find previous/next functions for navigation
const fnIndex = mapping.findIndex((f) => f.id === fnSlug);
const prevFn = fnIndex > 0 ? mapping[fnIndex - 1] : null;
const nextFn = fnIndex < mapping.length - 1 ? mapping[fnIndex + 1] : null;

// Devolution label
const devolutionLabel = fnDef.devolution === "obligatory"
  ? "Obligatory"
  : fnDef.devolution === "discretionary"
    ? "Discretionary"
    : "Not Devolved";

// Category label
const categoryLabel = fnDef.category === "core"
  ? "Core"
  : fnDef.category === "general"
    ? "General"
    : "Sector";

// Generate verdict explanation
function getVerdict(status: HealthStatus): string {
  const bPct = formatPercent(budgetShare);
  const cPct = formatPercent(complaintShare);
  switch (status) {
    case "critical":
      return `${bPct} of budget, ${cPct} of complaints. Severely underfunded relative to citizen demand.`;
    case "stressed":
      return `Budget-complaint mismatch. ${bPct} budget, ${cPct} complaints.`;
    case "unfunded":
      return `Mandated by act but receives less than 1% of budget allocation.`;
    case "good":
      return `Budget allocation aligns with citizen demand. Resolution rate above 80%.`;
  }
}

const verdictText = getVerdict(health.status);

const pageTitle = `${fnDef.name} — ${corpData.name}`;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: cityData.name, href: `/${cityId}` },
  { label: corpData.name, href: `/${cityId}/${corpId}` },
  { label: fnDef.name },
];
---

<BaseLayout title={pageTitle} description={`${fnDef.name} governance detail for ${corpData.name}`}>
  <Breadcrumb slot="breadcrumb" items={breadcrumbs} />

  <header class="fn-header">
    <h1>{fnDef.name}</h1>
    <p class="text-local">{fnDef.name_local}</p>
    <div class="fn-meta">
      <span class="fn-meta__tag fn-meta__tag--category">{categoryLabel}</span>
      <span class="fn-meta__tag fn-meta__tag--devolution">{devolutionLabel}</span>
      <HealthBadge status={health.status} size="md" />
    </div>
  </header>

  <!-- ── Section 1: THE MANDATE ────────────────────────── -->
  <section class="card narrative-section">
    <h2 class="section-label">The Mandate</h2>
    <div class="section-body">
      <dl class="detail-list">
        <div class="detail-item">
          <dt>Act</dt>
          <dd>{cityData.act.short_name} ({cityData.act.year})</dd>
        </div>
        <div class="detail-item">
          <dt>Section</dt>
          <dd>S. {fnDef.act_reference.section}, Schedule {fnDef.act_reference.schedule}</dd>
        </div>
        <div class="detail-item detail-item--full">
          <dt>Provision</dt>
          <dd class="provision-text">&ldquo;{fnDef.act_reference.text}&rdquo;</dd>
        </div>
        <div class="detail-item">
          <dt>Category</dt>
          <dd>{categoryLabel}</dd>
        </div>
        <div class="detail-item">
          <dt>Devolution</dt>
          <dd>{devolutionLabel}</dd>
        </div>
      </dl>
    </div>
  </section>

  <div class="flow-arrow" aria-hidden="true">&darr;</div>

  <!-- ── Section 2: THE MONEY ──────────────────────────── -->
  <section class="card narrative-section">
    <h2 class="section-label">The Money</h2>
    <div class="section-body">
      <div class="stat-row">
        <div class="stat-block">
          <span class="stat-value">{formatINR(budgetAmount)}</span>
          <span class="stat-label">Budget allocation ({budget.fiscal_year})</span>
        </div>
        <div class="stat-block">
          <span class="stat-value">{formatPercent(budgetShare)}</span>
          <span class="stat-label">Share of total expenditure</span>
        </div>
        <div class="stat-block">
          <span class="stat-value">{formatGrowth(yoyGrowth)}</span>
          <span class="stat-label">YoY growth</span>
        </div>
      </div>
      <p class="note-text mt-1">
        Historical budget expenditure variance: -32% (<a href="https://www.janaagraha.org/asics/" target="_blank" rel="noopener">ASICS 2023</a>)
      </p>
      <p class="source-cite mt-1">Source: Corporation budget book {budget.fiscal_year} (illustrative — pending extraction)</p>
    </div>
  </section>

  <div class="flow-arrow" aria-hidden="true">&darr;</div>

  <!-- ── Section 3: THE REALITY ────────────────────────── -->
  <section class="card narrative-section">
    <h2 class="section-label">The Reality</h2>
    <div class="section-body">
      <div class="stat-row">
        <div class="stat-block">
          <span class="stat-value">{formatNumber(complaintCount)}</span>
          <span class="stat-label">Complaints ({grievances.source})</span>
        </div>
        <div class="stat-block">
          <span class="stat-value">{formatPercent(complaintShare)}</span>
          <span class="stat-label">Share of total complaints</span>
        </div>
        <div class="stat-block">
          <span class="stat-value">{resolutionRate > 0 ? `${resolutionRate}%` : "N/A"}</span>
          <span class="stat-label">Resolution rate</span>
        </div>
      </div>
      {grievances.top_wards.length > 0 && (
        <div class="mt-1">
          <span class="text-sm text-muted">Top wards by volume:</span>
          <span class="text-sm">{grievances.top_wards.join(", ")}</span>
        </div>
      )}
      <p class="source-cite mt-1">Source: <a href="https://data.opencity.in/dataset/bbmp-grievances-data" target="_blank" rel="noopener">BBMP Sahaaya / OpenCity.in</a> (Feb 2020 &ndash; Jun 2025, 766K+ total complaints)</p>
    </div>
  </section>

  <div class="flow-arrow" aria-hidden="true">&darr;</div>

  <!-- ── Section 4: THE VERDICT ────────────────────────── -->
  <section class="card narrative-section narrative-section--verdict">
    <h2 class="section-label">The Verdict</h2>
    <div class="section-body verdict-body">
      <div class="verdict-badge">
        <HealthBadge status={health.status} size="md" />
      </div>
      <p class="verdict-text">{verdictText}</p>
      <dl class="verdict-stats">
        <div>
          <dt>Stress index</dt>
          <dd>{health.stress_index.toFixed(2)}</dd>
        </div>
        <div>
          <dt>Budget share</dt>
          <dd>{formatPercent(budgetShare)}</dd>
        </div>
        <div>
          <dt>Complaint share</dt>
          <dd>{formatPercent(complaintShare)}</dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- ── Navigation ────────────────────────────────────── -->
  <nav class="fn-nav">
    <div class="fn-nav__prev">
      {prevFn && (
        <a href={`/${cityId}/${corpId}/${prevFn.id}`}>&larr; {prevFn.name}</a>
      )}
    </div>
    <div class="fn-nav__center">
      <a href={`/${cityId}/compare/${fnDef.id}`}>Compare across corporations</a>
    </div>
    <div class="fn-nav__next">
      {nextFn && (
        <a href={`/${cityId}/${corpId}/${nextFn.id}`}>{nextFn.name} &rarr;</a>
      )}
    </div>
  </nav>
</BaseLayout>

<style>
  /* ── Function Header ──────────────────────────────────── */
  .fn-header {
    margin-bottom: 1.5rem;
  }
  .fn-header h1 {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--c-primary-dark);
    margin-bottom: 0.15rem;
  }
  .fn-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.6rem;
  }
  .fn-meta__tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .fn-meta__tag--category {
    background: #e0e7ff;
    color: #3730a3;
  }
  .fn-meta__tag--devolution {
    background: #f3f4f6;
    color: #4b5563;
  }

  /* ── Narrative Sections ───────────────────────────────── */
  .narrative-section {
    position: relative;
  }
  .section-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Detail List ──────────────────────────────────────── */
  .detail-list {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }
  .detail-item dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
    margin-bottom: 0.15rem;
  }
  .detail-item dd {
    font-size: 0.92rem;
    font-weight: 500;
  }
  .detail-item--full {
    grid-column: 1 / -1;
  }
  .provision-text {
    font-style: italic;
    color: var(--c-text);
    line-height: 1.5;
  }

  /* ── Stat Row ─────────────────────────────────────────── */
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
  }
  .stat-block {
    display: flex;
    flex-direction: column;
  }
  .stat-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--c-primary-dark);
    line-height: 1.2;
  }
  .stat-label {
    font-size: 0.75rem;
    color: var(--c-text-muted);
    margin-top: 0.2rem;
  }

  /* ── Note Text ────────────────────────────────────────── */
  .note-text {
    font-size: 0.8rem;
    color: var(--c-text-muted);
    font-style: italic;
    border-left: 3px solid var(--c-border);
    padding-left: 0.75rem;
  }

  /* ── Flow Arrow ───────────────────────────────────────── */
  .flow-arrow {
    text-align: center;
    font-size: 1.5rem;
    color: var(--c-text-muted);
    margin: 0.5rem 0;
    line-height: 1;
  }

  /* ── Verdict ──────────────────────────────────────────── */
  .narrative-section--verdict {
    border-left: 4px solid var(--c-primary);
  }
  .verdict-body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .verdict-badge {
    display: flex;
    align-items: center;
  }
  .verdict-text {
    font-size: 0.95rem;
    line-height: 1.6;
  }
  .verdict-stats {
    display: flex;
    gap: 1.5rem;
    margin-top: 0.25rem;
  }
  .verdict-stats dt {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }
  .verdict-stats dd {
    font-size: 1rem;
    font-weight: 600;
  }

  /* ── Function Navigation ──────────────────────────────── */
  .fn-nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--c-border);
    font-size: 0.88rem;
    gap: 1rem;
  }
  .fn-nav__prev,
  .fn-nav__next {
    flex: 1;
  }
  .fn-nav__next {
    text-align: right;
  }
  .fn-nav__center {
    text-align: center;
    flex-shrink: 0;
  }
  .fn-nav__center a {
    font-weight: 600;
    color: var(--c-primary);
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 640px) {
    .fn-header h1 {
      font-size: 1.3rem;
    }
    .detail-list {
      grid-template-columns: 1fr;
    }
    .stat-row {
      grid-template-columns: 1fr;
    }
    .stat-value {
      font-size: 1.2rem;
    }
    .verdict-stats {
      flex-direction: column;
      gap: 0.5rem;
    }
    .fn-nav {
      flex-direction: column;
      text-align: center;
    }
    .fn-nav__prev,
    .fn-nav__next {
      text-align: center;
    }
  }
</style>
