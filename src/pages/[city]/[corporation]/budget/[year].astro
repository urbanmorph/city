---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import HealthBadge from "../../../../components/HealthBadge.astro";
import { loadCity, loadCorporation, loadBudget, loadGrievances, loadFunctionMapping } from "../../../../lib/data-loader";
import { computeAllHealth } from "../../../../lib/health-score";
import { formatINR, formatNumber, formatPercent, formatGrowth } from "../../../../lib/format";
import type { FunctionHealth, FunctionMapping, HealthStatus } from "../../../../lib/types";

const { city: cityId, corporation: corpId, year } = Astro.params;

const city = loadCity(cityId!);
const corporation = loadCorporation(cityId!, corpId!);

if (!city || !corporation || !year) {
  return Astro.redirect("/404");
}

const mapping = loadFunctionMapping(city.id);
const budget = loadBudget(city.id, corporation.id, year);
const grievances = loadGrievances(city.id, corporation.id);

if (!budget) {
  return Astro.redirect(`/${city.id}/${corporation.id}`);
}

// Compute health for all functions
let healthList: FunctionHealth[] = [];
if (grievances) {
  healthList = computeAllHealth(corporation.id, budget, grievances, mapping);
}

// Build rows: merge mapping + budget + grievance + health per function
interface BudgetRow {
  fn: FunctionMapping;
  amount: number;
  share: number;
  yoyGrowth: number;
  complaints: number;
  complaintShare: number;
  health: FunctionHealth | null;
}

const rows: BudgetRow[] = mapping.map((fn) => {
  const budgetEntry = budget.by_function[fn.id];
  const grievanceEntry = grievances?.by_function[fn.id];
  const health = healthList.find((h) => h.function_id === fn.id) ?? null;

  return {
    fn,
    amount: budgetEntry?.amount ?? 0,
    share: budgetEntry?.share ?? 0,
    yoyGrowth: budgetEntry?.yoy_growth ?? 0,
    complaints: grievanceEntry?.count ?? 0,
    complaintShare: grievanceEntry?.share ?? 0,
    health,
  };
});

// Sort by budget allocation descending
rows.sort((a, b) => b.amount - a.amount);

// Totals
const totalBudgetLakhs = rows.reduce((sum, r) => sum + r.amount, 0);
const totalComplaints = rows.reduce((sum, r) => sum + r.complaints, 0);

// Category breakdowns
const categories: Array<{ label: string; key: "core" | "general" | "sector" }> = [
  { label: "Core Functions", key: "core" },
  { label: "General Functions", key: "general" },
  { label: "Sector Functions", key: "sector" },
];

const categoryStats = categories.map(({ label, key }) => {
  const catRows = rows.filter((r) => r.fn.category === key);
  const catBudget = catRows.reduce((sum, r) => sum + r.amount, 0);
  return { label, count: catRows.length, budget: catBudget };
});

// Short corporation label for breadcrumb
const corpShortName = corporation.name.replace(`${city.name} `, "").replace(" City Corporation", "");
---

<BaseLayout
  title={`Budget ${year} — ${corporation.name}`}
  description={`Full budget table for ${corporation.name}, fiscal year ${year}`}
>
  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: city.name, href: `/${city.id}` },
      { label: corpShortName, href: `/${city.id}/${corporation.id}` },
      { label: `Budget ${year}` },
    ]}
  />

  <section class="page-header">
    <h1>{corporation.name} &mdash; Budget {year}</h1>
    <p class="text-local">{corporation.name_local}</p>
  </section>

  <!-- Summary cards -->
  <div class="summary-row mt-2">
    <div class="summary-card">
      <span class="summary-label">Total Revenue</span>
      <span class="summary-value">{formatINR(budget.summary.total_revenue)}</span>
    </div>
    <div class="summary-card">
      <span class="summary-label">Total Expenditure</span>
      <span class="summary-value">{formatINR(budget.summary.total_expenditure)}</span>
    </div>
    <div class="summary-card summary-card--note">
      <span class="summary-label">Data Note</span>
      <span class="summary-note">Placeholder data — actual values pending PDF extraction. Historical variance: -32% between approved and actual spend.</span>
    </div>
  </div>

  <!-- Full budget table -->
  <div class="table-wrap mt-2">
    <table class="data-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Function</th>
          <th>Act Reference</th>
          <th class="num">Budget Allocation</th>
          <th class="num">% of Total</th>
          <th class="num">YoY Growth</th>
          <th class="num">Complaints</th>
          <th class="num">Complaint Share</th>
          <th>Health</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((row, i) => (
          <tr>
            <td>{i + 1}</td>
            <td>
              <a href={`/${city.id}/${corporation.id}/${row.fn.id}`}>{row.fn.name}</a>
            </td>
            <td class="text-sm text-muted">S. {row.fn.act_reference.section}</td>
            <td class="num">{formatINR(row.amount)}</td>
            <td class="num">{formatPercent(row.share)}</td>
            <td class={`num ${row.yoyGrowth >= 0 ? "growth-positive" : "growth-negative"}`}>
              {formatGrowth(row.yoyGrowth)}
            </td>
            <td class="num">{row.complaints > 0 ? formatNumber(row.complaints) : "—"}</td>
            <td class="num">{row.complaintShare > 0 ? formatPercent(row.complaintShare) : "—"}</td>
            <td>
              {row.health
                ? <HealthBadge status={row.health.status} />
                : <span class="text-muted text-sm">N/A</span>
              }
            </td>
          </tr>
        ))}
      </tbody>
      <tfoot>
        <tr class="totals-row">
          <td></td>
          <td><strong>Total</strong></td>
          <td></td>
          <td class="num"><strong>{formatINR(totalBudgetLakhs)}</strong></td>
          <td class="num"><strong>100%</strong></td>
          <td></td>
          <td class="num"><strong>{formatNumber(totalComplaints)}</strong></td>
          <td></td>
          <td></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- Category breakdown -->
  <section class="category-section mt-2">
    <h2>Budget by Category</h2>
    <div class="category-grid">
      {categoryStats.map((cat) => (
        <div class="category-card card">
          <h3>{cat.label}</h3>
          <p class="category-budget">{formatINR(cat.budget)}</p>
          <p class="text-sm text-muted">{cat.count} functions &mdash; {formatPercent(totalBudgetLakhs > 0 ? cat.budget / totalBudgetLakhs : 0)} of total</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Bottom navigation -->
  <nav class="page-links mt-2">
    <a href={`/${city.id}/${corporation.id}`} class="link-btn">Corporation Scorecard</a>
    <a href={`/${city.id}/compare`} class="link-btn">Compare Corporations</a>
    <a href={`/${city.id}/act`} class="link-btn">{city.act.short_name}</a>
  </nav>
</BaseLayout>

<style>
  .page-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-primary);
  }

  /* Summary row */
  .summary-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .summary-card {
    flex: 1;
    min-width: 200px;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .summary-card--note {
    flex: 2;
    min-width: 280px;
  }
  .summary-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }
  .summary-value {
    font-size: 1.35rem;
    font-weight: 700;
    color: var(--c-text);
  }
  .summary-note {
    font-size: 0.82rem;
    color: var(--c-text-muted);
    line-height: 1.5;
  }

  /* Table numeric alignment */
  .num {
    text-align: right;
    white-space: nowrap;
  }
  .growth-positive {
    color: #166534;
  }
  .growth-negative {
    color: #991b1b;
  }

  /* Totals row */
  .totals-row td {
    background: #e8ecf0;
    border-top: 2px solid var(--c-primary);
    font-weight: 600;
  }

  /* Category breakdown */
  .category-section h2 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .category-card h3 {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-primary);
    margin-bottom: 0.35rem;
  }
  .category-budget {
    font-size: 1.25rem;
    font-weight: 700;
  }

  /* Bottom nav */
  .page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .link-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-primary);
    border: 1px solid var(--c-primary);
    border-radius: var(--radius);
    transition: background 0.15s, color 0.15s;
  }
  .link-btn:hover {
    background: var(--c-primary);
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .page-header h1 {
      font-size: 1.2rem;
    }
    .summary-row {
      flex-direction: column;
    }
    .summary-card {
      min-width: unset;
    }
    .summary-value {
      font-size: 1.1rem;
    }
    .category-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
