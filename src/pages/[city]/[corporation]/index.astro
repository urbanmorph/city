---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import DepartmentRow from "../../../components/DepartmentRow.astro";
import { loadCity, loadCorporation, loadBudget, loadGrievances, loadFunctionMapping, loadDepartments } from "../../../lib/data-loader";
import { computeDepartmentHealth, countByStatus } from "../../../lib/health-score";
import { formatINR, formatNumber } from "../../../lib/format";
import type { DepartmentHealth, HealthStatus } from "../../../lib/types";

const { city: cityId, corporation: corpId } = Astro.params;

const city = loadCity(cityId!);
const corporation = loadCorporation(cityId!, corpId!);

if (!city || !corporation) {
  return Astro.redirect("/404");
}

const mapping = loadFunctionMapping(city.id);
const budget = loadBudget(city.id, corporation.id, city.budget_year);
const grievances = loadGrievances(city.id, corporation.id);
const { departments, external_entities } = loadDepartments(city.id);

// Compute health for all departments
let deptHealthList: DepartmentHealth[] = [];
let statusCounts: Record<HealthStatus, number> = { good: 0, stressed: 0, critical: 0, unfunded: 0 };

if (budget && grievances) {
  deptHealthList = departments.map((d) => computeDepartmentHealth(d, corporation.id, budget, grievances));
  statusCounts = countByStatus(deptHealthList);
}

// Sort: stress index descending, then unfunded, then good last
const sortedDepts = departments.map((dept) => {
  const health = deptHealthList.find((h) => h.department_id === dept.id);
  return { dept, health };
}).sort((a, b) => {
  const aStress = a.health?.stress_index ?? 0;
  const bStress = b.health?.stress_index ?? 0;
  const aScore = a.health?.status === "unfunded" ? 999 : aStress;
  const bScore = b.health?.status === "unfunded" ? 999 : bStress;
  return bScore - aScore;
});

// Summary stats
const totalBudgetLakhs = budget?.summary.total_expenditure ?? 0;
const totalComplaints = grievances?.total_complaints ?? 0;
const resolutionRate = grievances?.resolution_rate ?? 0;

// Functions delivered by external entities (not by any corp dept)
const corpFunctionIds = new Set(departments.flatMap((d) => d.functions.map((f) => f.id)));
const externalFunctions = mapping.filter((fn) => !corpFunctionIds.has(fn.id));
// Also pull entities that handle these
function entitiesForFunction(fnId: string) {
  return external_entities.filter((e) => e.functions.some((f) => f.id === fnId));
}

function fallbackHealth(deptId: string): DepartmentHealth {
  return {
    department_id: deptId,
    corporation_id: corporation.id,
    budget_amount: 0,
    budget_share: 0,
    staff_amount: 0,
    staff_pct_of_budget: 0,
    complaint_count: 0,
    complaint_share: 0,
    resolution_rate: 0,
    stress_index: 0,
    status: "good" as HealthStatus,
  };
}
---

<BaseLayout
  title={`${corporation.name} — ${city.name}`}
  description={`Scorecard for ${corporation.name} across ${mapping.length} civic functions`}
>
  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: city.name, href: `/${city.id}` },
      { label: corporation.name.replace(`${city.name} `, "").replace(" City Corporation", "") },
    ]}
  />

  <section class="corp-header">
    <h1>{corporation.name}</h1>
    <p class="text-local">{corporation.name_local}</p>
    <p class="text-sm text-muted mt-1">{corporation.wards} wards &mdash; Budget year {corporation.budget_year}</p>
  </section>

  <dl class="stat-row mt-2">
    <div class="stat-item">
      <dt>Departments</dt>
      <dd>{departments.length}</dd>
    </div>
    <div class="stat-item">
      <dt>Total Budget</dt>
      <dd>{formatINR(totalBudgetLakhs)}</dd>
    </div>
    <div class="stat-item">
      <dt>Complaints</dt>
      <dd>{formatNumber(totalComplaints)}</dd>
    </div>
    <div class="stat-item">
      <dt>Resolution Rate</dt>
      <dd>{resolutionRate.toFixed(1)}%</dd>
    </div>
    <div class="stat-item">
      <dt>Staff / Lakh</dt>
      <dd>317</dd>
    </div>
    <div class="stat-item">
      <dt>Vacancy</dt>
      <dd>52%</dd>
    </div>
  </dl>

  <div class="status-summary mt-2">
    <span class="status-count status-count--good">{statusCounts.good} Good</span>
    <span class="status-count status-count--stressed">{statusCounts.stressed} Stressed</span>
    <span class="status-count status-count--critical">{statusCounts.critical} Critical</span>
    <span class="status-count status-count--unfunded">{statusCounts.unfunded} Unfunded</span>
    {statusCounts.no_data > 0 && (
      <span class="status-count status-count--no_data">{statusCounts.no_data} No Data</span>
    )}
  </div>

  {budget && grievances ? (
    <>
      <h2 class="section-title mt-2">Departments &mdash; what the corporation does</h2>
      <p class="text-sm text-muted">
        {departments.length} departments deliver {Array.from(corpFunctionIds).length} of the {mapping.length} GBA Act-mandated functions.
      </p>
      <div class="table-wrap mt-1">
        <table class="data-table">
          <thead>
            <tr>
              <th>Department</th>
              <th>Budget</th>
              <th>Staff</th>
              <th>Complaints</th>
              <th>Health</th>
            </tr>
          </thead>
          <tbody>
            {sortedDepts.map(({ dept, health }) => (
              <DepartmentRow
                dept={dept}
                health={health ?? fallbackHealth(dept.id)}
                cityId={city.id}
                corpId={corporation.id}
                functionMapping={mapping}
              />
            ))}
          </tbody>
        </table>
      </div>

      {externalFunctions.length > 0 && (
        <section class="external-section mt-2">
          <h2 class="section-title">Outside the corporation &mdash; who actually does this</h2>
          <p class="text-sm text-muted mb-1">
            {externalFunctions.length} of the {mapping.length} GBA Act functions are delivered by parastatals or state departments, not the city corporation.
          </p>
          <div class="external-grid mt-1">
            {externalFunctions.map((fn) => {
              const ents = entitiesForFunction(fn.id);
              return (
                <div class="external-item">
                  <div class="external-fn">
                    <span class="external-fn__name">{fn.name}</span>
                    <span class="external-fn__ref">S. {fn.act_reference.section}</span>
                  </div>
                  <div class="external-ents">
                    {ents.length > 0 ? ents.map((e) => (
                      <a href={e.url} target="_blank" rel="noopener" class="external-ent" title={e.functions.find(f => f.id === fn.id)?.scope}>
                        <strong>{e.abbr}</strong> <span class="text-sm text-muted">{e.name}</span>
                      </a>
                    )) : (
                      <span class="text-sm text-muted">No external entity mapped</span>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </section>
      )}
    </>
  ) : (
    <div class="card mt-2">
      <p class="text-muted">Budget or grievance data not available for this corporation.</p>
    </div>
  )}

  <nav class="page-links mt-2">
    <a href={`/${city.id}/${corporation.id}/budget/${corporation.budget_year}`} class="link-btn">Full Budget</a>
    <a href={`/${city.id}/act`} class="link-btn">{city.act.short_name}</a>
    <a href={`/${city.id}/compare`} class="link-btn">Compare Corporations</a>
  </nav>
</BaseLayout>

<style>
  .corp-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-primary);
  }
  .stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .stat-item dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }
  .stat-item dd {
    font-size: 1.25rem;
    font-weight: 700;
  }
  .status-summary {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .status-count {
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius);
  }
  .status-count--good { background: #dcfce7; color: #166534; }
  .status-count--stressed { background: #fef9c3; color: #854d0e; }
  .status-count--critical { background: #fee2e2; color: #991b1b; }
  .status-count--unfunded { background: #f3f4f6; color: #4b5563; }
  .status-count--no_data { background: #ffffff; color: #6b7280; border: 1px dashed #d1d5db; }

  .section-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--c-primary);
    margin-top: 1.5rem;
  }

  /* External entities */
  .external-section {
    padding-top: 0.5rem;
  }
  .external-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }
  .external-item {
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-left: 3px solid var(--c-accent);
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
  }
  .external-fn {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
  }
  .external-fn__name {
    font-weight: 600;
    color: var(--c-text);
  }
  .external-fn__ref {
    font-size: 0.7rem;
    color: var(--c-text-muted);
  }
  .external-ents {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .external-ent {
    font-size: 0.85rem;
    text-decoration: none;
    color: var(--c-primary);
  }
  .external-ent:hover {
    text-decoration: underline;
  }

  .page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .link-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-primary);
    border: 1px solid var(--c-primary);
    border-radius: var(--radius);
    transition: background 0.15s, color 0.15s;
  }
  .link-btn:hover {
    background: var(--c-primary);
    color: #fff;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .corp-header h1 { font-size: 1.25rem; }
    .stat-row { gap: 1rem; }
    .stat-item dd { font-size: 1.05rem; }
    .status-summary { gap: 0.5rem; }
    .status-count { font-size: 0.8rem; padding: 0.2rem 0.5rem; }
    .external-grid { grid-template-columns: 1fr; }
  }
</style>
