---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import { loadCity, loadCorporation, loadLineItemBudget, loadSpeechProjects } from "../../../lib/data-loader";
import { formatINR } from "../../../lib/format";

const { city: cityId, corporation: corpId } = Astro.params;

const city = loadCity(cityId!);
const corporation = loadCorporation(cityId!, corpId!);

if (!city || !corporation) {
  return Astro.redirect("/404");
}

const data = loadLineItemBudget(city.id, corporation.id);
const speech = loadSpeechProjects(city.id, corporation.id);

// Group speech projects by function_code
type SpeechProj = NonNullable<typeof speech>["projects"][number];
const projectsByFn = new Map<string, SpeechProj[]>();
for (const p of speech?.projects ?? []) {
  const code = p.function_code ?? "unmapped";
  if (!projectsByFn.has(code)) projectsByFn.set(code, []);
  projectsByFn.get(code)!.push(p);
}

// Function meta in display order (matches budget functions, plus an "Unmapped" bucket)
const speechFunctionOrder = [
  { code: "01", name: "Council" },
  { code: "02", name: "General Administration" },
  { code: "03", name: "Revenue" },
  { code: "04", name: "Town Planning and Regulation" },
  { code: "05", name: "Public Works" },
  { code: "06", name: "Solid Waste Management" },
  { code: "07", name: "Public Health-General" },
  { code: "08", name: "Public Health-Medical" },
  { code: "09", name: "Horticulture" },
  { code: "10", name: "Urban Forestry" },
  { code: "11", name: "Public Education" },
  { code: "12", name: "Social Welfare" },
];

function fmtYoY(pct: number | null | undefined): string {
  if (pct === null || pct === undefined) return "";
  const sign = pct >= 0 ? "+" : "";
  return `${sign}${pct.toFixed(1)}%`;
}

function yoyClass(pct: number | null | undefined): string {
  if (pct === null || pct === undefined) return "yoy-none";
  if (pct > 0) return "yoy-up";
  if (pct < 0) return "yoy-down";
  return "yoy-zero";
}

function cleanName(s: string): string {
  // Strip stray em-dashes, double-spaces, orphan commas/punctuation
  return s
    .replace(/\s[—–]\s/g, ", ")
    .replace(/\s*,\s*,+/g, ", ")
    .replace(/\s{2,}/g, " ")
    .replace(/[,.\s]+$/g, "")
    .trim();
}
---

<BaseLayout
  title={`${corporation.name} Budget Detail ${data?.fiscal_year ?? "2026-27"}`}
  description={`Function, sub-category and line-item budget for ${corporation.name}`}
>
  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: city.name, href: `/${city.id}` },
      {
        label: corporation.name.replace(`${city.name} `, "").replace(" City Corporation", ""),
      },
    ]}
  />

  <header class="page-head">
    <div class="eyebrow">Fiscal Year {data?.fiscal_year ?? "2026-27"}</div>
    <h1>{corporation.name}</h1>
    <p class="lede">
      What was announced in the Commissioner's budget speech, and the line-item budget behind it. Switch tabs to move between the two views.
    </p>
  </header>

  {data ? (
    <>
      <section class="topline">
        <div class="tl-cell">
          <span class="tl-label">Total</span>
          <span class="tl-value">{formatINR(data.total_2026_27)}</span>
          <span class="tl-sub">2026 {`\u2013`}27 Budget Estimate</span>
        </div>
        <div class="tl-cell">
          <span class="tl-label">Previous</span>
          <span class="tl-value tl-value--muted">{formatINR(data.total_revised_2025_26)}</span>
          <span class="tl-sub">2025 {`\u2013`}26 Revised</span>
        </div>
        <div class="tl-cell">
          <span class="tl-label">YoY</span>
          <span class={`tl-value tl-yoy ${yoyClass(data.yoy_pct)}`}>{fmtYoY(data.yoy_pct) || "no data"}</span>
          <span class="tl-sub">Year on year</span>
        </div>
        <div class="tl-cell">
          <span class="tl-label">Spillover</span>
          <span class="tl-value tl-value--accent">{data.total_spillover > 0 ? formatINR(data.total_spillover) : "nil"}</span>
          <span class="tl-sub">Pending from earlier years</span>
        </div>
      </section>

      <nav class="tabs" role="tablist" aria-label="Budget views">
        <button type="button" class="tab" role="tab" aria-selected={speech ? "true" : "false"} data-tab-target="speech" disabled={!speech}>
          <i class="fa-solid fa-microphone-lines"></i>
          Budget Speech
          {speech && <span class="tab-count">{speech.projects.length}</span>}
        </button>
        <button type="button" class="tab" role="tab" aria-selected={speech ? "false" : "true"} data-tab-target="detail">
          <i class="fa-solid fa-table-list"></i>
          Budget Detail
        </button>
      </nav>

      {speech && (
        <section class="tab-panel" data-tab="speech" aria-hidden="false">
          <aside class="note-card">
            <i class="fa-solid fa-circle-info"></i>
            <div>
              <strong>From the Commissioner's Budget Speech, {new Date(speech.speech_date).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}.</strong>
              {` `}{speech.projects.length} projects and initiatives announced by {speech.commissioner}, grouped here against the 12 budget functions using a keyword heuristic. Tagging is provisional and can be refined.
            </div>
          </aside>

          <div class="speech-grid">
            {speechFunctionOrder.map((fn) => {
              const items = projectsByFn.get(fn.code) ?? [];
              if (items.length === 0) return null;
              const withAmount = items.filter((p) => p.amount_lakhs != null);
              const totalLakhs = withAmount.reduce((sum, p) => sum + (p.amount_lakhs ?? 0), 0);
              return (
                <details class="speech-fn-block" open>
                  <summary class="fn-summary">
                    <span class="fn-lead">
                      <i class="fa-solid fa-chevron-right chev"></i>
                      <span class="fn-code">{fn.code}</span>
                      <span class="fn-name">{fn.name}</span>
                    </span>
                    <span class="fn-meta">
                      <span class="pill pill-count">{items.length} {items.length === 1 ? "project" : "projects"}</span>
                      {totalLakhs > 0 && <span class="fn-amount">{formatINR(totalLakhs)}</span>}
                    </span>
                  </summary>
                  <ul class="speech-list">
                    {items.map((p) => (
                      <li class="speech-item">
                        <div class="speech-item-main">
                          <span class="speech-item-name">{p.name}</span>
                          {p.description && p.description !== p.name && (
                            <span class="speech-item-desc">{p.description}</span>
                          )}
                          <span class="speech-item-foot">
                            <span class="speech-page">p.{p.page}</span>
                            <span class="speech-reason" title={p.tag_reason}>{p.tag_reason}</span>
                          </span>
                        </div>
                        <div class="speech-item-meta">
                          {p.amount_lakhs != null ? (
                            <span class="speech-amount">{formatINR(p.amount_lakhs)}</span>
                          ) : (
                            <span class="speech-amount speech-amount--none">no amount</span>
                          )}
                        </div>
                      </li>
                    ))}
                  </ul>
                </details>
              );
            })}
          </div>

          <p class="source-line">
            Source: Budget Speech {data.fiscal_year}, {corporation.name}, delivered by {speech.commissioner} on {new Date(speech.speech_date).toLocaleDateString("en-IN", { day: "numeric", month: "long", year: "numeric" })}. Function tags are provisional — assigned by keyword heuristic and open to refinement.
          </p>
        </section>
      )}

      <section class="tab-panel" data-tab="detail" aria-hidden={speech ? "true" : "false"}>
        <div class="toolbar">
          <div class="toolbar-left">
            <button type="button" class="tool-btn" data-action="expand-all">
              <i class="fa-solid fa-chevrons-down"></i> Expand all
            </button>
            <button type="button" class="tool-btn" data-action="collapse-all">
              <i class="fa-solid fa-chevrons-up"></i> Collapse all
            </button>
          </div>
          <div class="toolbar-right">
            <span class="legend">
              <span class="swatch swatch-up"></span> budget grew
            </span>
            <span class="legend">
              <span class="swatch swatch-down"></span> budget shrank
            </span>
            <span class="legend">
              <span class="swatch swatch-spill"></span> spillover
            </span>
          </div>
        </div>

        <aside class="note-card">
          <i class="fa-solid fa-circle-info"></i>
          <div>
            <strong>Extracted from the OpenCity.in budget PDF.</strong> Captured {formatINR(data.total_2026_27)} of a book total of {`\u20B9`}3,826 Cr ({(data.total_2026_27 / 382595 * 100).toFixed(1)}% coverage). The remaining {`\u20B9`}{Math.round((382595 - data.total_2026_27) / 100)} Cr sit in rows where codes span columns irregularly on a handful of pages.
          </div>
        </aside>

        <section class="tree">
          {data.functions.map((fn) => (
            <details class="fn-block" open={fn.code === "05"}>
              <summary class="fn-summary">
                <span class="fn-lead">
                  <i class="fa-solid fa-chevron-right chev"></i>
                  <span class="fn-code">{fn.code}</span>
                  <span class="fn-name">{cleanName(fn.name)}</span>
                </span>
                <span class="fn-meta">
                  {fn.spillover > 0 && (
                    <span class="pill pill-spill">
                      <i class="fa-solid fa-clock-rotate-left"></i>
                      {formatINR(fn.spillover)}
                    </span>
                  )}
                  <span class={`pill pill-yoy ${yoyClass(fn.yoy_pct)}`}>{fmtYoY(fn.yoy_pct) || "—"}</span>
                  <span class="fn-amount">{formatINR(fn.total_2026_27)}</span>
                </span>
              </summary>
              <div class="sub-list">
                {fn.sub_categories.length === 0 && (
                  <p class="no-data">No line items captured for this function yet.</p>
                )}
                {fn.sub_categories.map((sub) => (
                  <details class="sub-block">
                    <summary class="sub-summary">
                      <span class="sub-lead">
                        <i class="fa-solid fa-chevron-right chev chev-sm"></i>
                        <span class="sub-name">{cleanName(sub.name)}</span>
                      </span>
                      <span class="sub-meta">
                        {sub.spillover > 0 && (
                          <span class="pill pill-spill pill-sm">
                            <i class="fa-solid fa-clock-rotate-left"></i>
                            {formatINR(sub.spillover)}
                          </span>
                        )}
                        <span class={`pill pill-yoy pill-sm ${yoyClass(sub.yoy_pct)}`}>{fmtYoY(sub.yoy_pct) || "—"}</span>
                        <span class="sub-amount">{formatINR(sub.total_2026_27)}</span>
                      </span>
                    </summary>
                    <ul class="item-list">
                      {sub.items.map((it) => (
                        <li class="item">
                          <span class="item-main">
                            <span class="item-code">{it.code}</span>
                            <span class="item-name">{cleanName(it.name)}</span>
                          </span>
                          <span class="item-meta">
                            {(it.pending ?? 0) > 0 && (
                              <span class="pill pill-spill pill-xs">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                {formatINR(it.pending!)}
                              </span>
                            )}
                            <span class={`pill pill-yoy pill-xs ${yoyClass(it.yoy_pct)}`}>{fmtYoY(it.yoy_pct) || "—"}</span>
                            <span class="item-amount">{formatINR(it.total_2026_27)}</span>
                          </span>
                        </li>
                      ))}
                    </ul>
                  </details>
                ))}
              </div>
            </details>
          ))}
        </section>

        <p class="source-line">
          Source: <a href="https://data.opencity.in/dataset/gba-corporation-budgets-2026-27" rel="noopener" target="_blank">Corporation Budget Book {data.fiscal_year}</a>, OpenCity.in. Amounts in Indian Rupees (Lakh below one Crore, Crore above).
        </p>
      </section>
    </>
  ) : (
    <div class="card mt-2">
      <p class="text-muted">Line-item budget data not available for this corporation.</p>
    </div>
  )}
</BaseLayout>

<script is:inline>
  document.addEventListener("click", (e) => {
    const t = e.target;
    if (!(t instanceof HTMLElement)) return;

    const tab = t.closest("[data-tab-target]");
    if (tab) {
      const target = tab.getAttribute("data-tab-target");
      document.querySelectorAll("[data-tab-target]").forEach((b) =>
        b.setAttribute("aria-selected", b.getAttribute("data-tab-target") === target ? "true" : "false")
      );
      document.querySelectorAll("[data-tab]").forEach((panel) =>
        panel.setAttribute("aria-hidden", panel.getAttribute("data-tab") === target ? "false" : "true")
      );
      return;
    }

    const btn = t.closest("[data-action]");
    if (!btn) return;
    const action = btn.getAttribute("data-action");
    const panel = btn.closest("[data-tab]") ?? document;
    const all = panel.querySelectorAll("details.fn-block, details.sub-block");
    if (action === "expand-all") all.forEach((d) => (d.open = true));
    if (action === "collapse-all") all.forEach((d) => (d.open = false));
  });
</script>

<style>
  :root {
    --num-font: "Inter", ui-sans-serif, system-ui, sans-serif;
    --c-ink: #1a202c;
    --c-ink-soft: #4a5568;
    --c-rule: #e2e8f0;
    --c-rule-soft: #edf2f7;
    --c-good: #137752;
    --c-good-bg: #e7f5ee;
    --c-bad: #9b2c2c;
    --c-bad-bg: #fdeceb;
    --c-neutral: #718096;
    --c-neutral-bg: #edf2f7;
    --c-spill: #9a6700;
    --c-spill-bg: #fff4cc;
  }

  .page-head {
    text-align: left;
    margin: 2rem 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--c-rule);
  }
  .page-head .eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-soft);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .page-head h1 {
    text-align: left;
    font-size: clamp(1.75rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--c-ink);
    margin: 0;
  }
  .page-head .lede {
    margin: 0.75rem 0 0;
    max-width: 68ch;
    color: var(--c-ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  /* Topline grid */
  .topline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--c-card);
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
  .tl-cell {
    padding: 1.1rem 1.25rem;
    border-right: 1px solid var(--c-rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #fff;
  }
  .tl-cell:last-child { border-right: none; }
  .tl-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-soft);
    font-weight: 600;
  }
  .tl-value {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .tl-value--muted { color: var(--c-ink-soft); font-weight: 600; }
  .tl-value--accent { color: var(--c-spill); }
  .tl-value.yoy-up { color: var(--c-good); }
  .tl-value.yoy-down { color: var(--c-bad); }
  .tl-value.yoy-zero, .tl-value.yoy-none { color: var(--c-neutral); }
  .tl-sub {
    font-size: 0.74rem;
    color: var(--c-neutral);
  }

  /* Toolbar */
  .toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin: 1.25rem 0 0.75rem;
  }
  .toolbar-left { display: flex; gap: 0.5rem; }
  .toolbar-right {
    display: flex;
    gap: 0.9rem;
    font-size: 0.78rem;
    color: var(--c-ink-soft);
  }
  .legend { display: inline-flex; align-items: center; gap: 0.35rem; }
  .swatch {
    width: 10px; height: 10px; border-radius: 2px; display: inline-block;
  }
  .swatch-up { background: var(--c-good); }
  .swatch-down { background: var(--c-bad); }
  .swatch-spill { background: var(--c-spill); }

  .tool-btn {
    font-family: var(--num-font);
    font-size: 0.85rem;
    font-weight: 600;
    padding: 0.45rem 0.85rem;
    background: #fff;
    border: 1px solid var(--c-rule);
    border-radius: 6px;
    color: var(--c-ink);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.15s ease;
  }
  .tool-btn:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: #f7fafc;
  }
  .tool-btn i { font-size: 0.75rem; }

  /* Note card */
  .note-card {
    display: flex;
    gap: 0.65rem;
    padding: 0.8rem 1rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    border-left: 3px solid var(--c-accent);
    border-radius: 6px;
    color: #78350f;
    font-size: 0.86rem;
    line-height: 1.55;
    margin-bottom: 1.25rem;
  }
  .note-card i { color: var(--c-spill); margin-top: 0.2rem; }

  /* Tree */
  .tree {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .fn-block {
    background: #fff;
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .fn-block[open] {
    border-color: var(--c-primary);
    box-shadow: 0 1px 2px rgba(0,0,0,0.03);
  }

  summary { list-style: none; cursor: pointer; }
  summary::-webkit-details-marker { display: none; }

  .fn-summary {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
  }
  .fn-summary:hover { background: #f8fafc; }
  .fn-lead {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 0.85rem;
    min-width: 0;
  }
  .chev {
    color: var(--c-neutral);
    transition: transform 0.2s ease;
    font-size: 0.8rem;
    width: 0.9rem;
    flex-shrink: 0;
  }
  details[open] > summary .chev { transform: rotate(90deg); }
  .chev-sm { font-size: 0.7rem; color: var(--c-neutral); }

  .fn-code {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--c-neutral);
    background: var(--c-rule-soft);
    border-radius: 4px;
    padding: 0.15rem 0.5rem;
    letter-spacing: 0.04em;
  }
  .fn-name {
    font-size: 1.02rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .fn-meta, .sub-meta, .item-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .fn-amount {
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--c-ink);
    letter-spacing: -0.01em;
    min-width: 6rem;
    text-align: right;
  }

  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    line-height: 1.3;
    font-feature-settings: "tnum";
  }
  .pill-sm { font-size: 0.72rem; padding: 0.15rem 0.5rem; }
  .pill-xs { font-size: 0.7rem; padding: 0.1rem 0.45rem; }

  .pill-yoy { min-width: 3.8rem; justify-content: center; }
  .pill-yoy.yoy-up { background: var(--c-good-bg); color: var(--c-good); }
  .pill-yoy.yoy-down { background: var(--c-bad-bg); color: var(--c-bad); }
  .pill-yoy.yoy-zero { background: var(--c-neutral-bg); color: var(--c-neutral); }
  .pill-yoy.yoy-none { background: transparent; color: var(--c-neutral); border: 1px dashed var(--c-rule); }

  .pill-spill {
    background: var(--c-spill-bg);
    color: var(--c-spill);
  }
  .pill-spill i { font-size: 0.7em; }

  /* Sub level */
  .sub-list {
    border-top: 1px solid var(--c-rule);
    background: #fafbfc;
    padding: 0.25rem 0;
  }
  .no-data {
    padding: 0.75rem 1.25rem;
    margin: 0;
    font-size: 0.85rem;
    color: var(--c-neutral);
    font-style: italic;
  }

  .sub-block {
    border-bottom: 1px solid var(--c-rule-soft);
  }
  .sub-block:last-child { border-bottom: none; }

  .sub-summary {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 0.7rem 1.1rem 0.7rem 2.4rem;
  }
  .sub-summary:hover { background: #f1f5f9; }
  .sub-lead {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    min-width: 0;
  }
  .sub-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--c-ink);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .sub-amount {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--c-ink);
    min-width: 5.5rem;
    text-align: right;
  }

  /* Item level */
  .item-list {
    list-style: none;
    margin: 0;
    padding: 0.4rem 1.1rem 0.7rem 3.5rem;
    background: #fff;
    border-top: 1px solid var(--c-rule-soft);
  }
  .item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: baseline;
