---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import {
  loadCity,
  loadCorporations,
  loadFunctionMapping,
  loadBudget,
  loadGrievances,
} from "../../../lib/data-loader";
import { computeFunctionHealth } from "../../../lib/health-score";
import { formatINR, formatNumber } from "../../../lib/format";
import type { FunctionMapping, HealthStatus } from "../../../lib/types";

const { city: cityId } = Astro.params;

const city = loadCity(cityId!);
if (!city) {
  return Astro.redirect("/404");
}

const mapping = loadFunctionMapping(city.id);
const corporations = loadCorporations(city.id);

// For each corporation, load budget + grievances
const corpData = corporations.map((corp) => {
  const budget = loadBudget(city.id, corp.id, city.budget_year);
  const grievances = loadGrievances(city.id, corp.id);
  return { corp, budget, grievances };
});

// Compute per-function aggregates across all corporations
interface FunctionAggregate {
  fn: FunctionMapping;
  totalBudget: number;
  totalComplaints: number;
  avgResolutionRate: number;
  healthCounts: Record<HealthStatus, number>;
  corpsWithData: number;
}

const aggregates: FunctionAggregate[] = mapping.map((fn) => {
  let totalBudget = 0;
  let totalComplaints = 0;
  let resolutionSum = 0;
  let corpsWithData = 0;
  const healthCounts: Record<HealthStatus, number> = {
    good: 0,
    stressed: 0,
    critical: 0,
    unfunded: 0,
  };

  for (const { corp, budget, grievances } of corpData) {
    if (!budget || !grievances) continue;
    corpsWithData++;

    const health = computeFunctionHealth(fn.id, corp.id, budget, grievances, mapping);
    totalBudget += health.budget_amount;
    totalComplaints += health.complaint_count;
    resolutionSum += health.resolution_rate;
    healthCounts[health.status]++;
  }

  const avgResolutionRate = corpsWithData > 0 ? resolutionSum / corpsWithData : 0;

  return {
    fn,
    totalBudget,
    totalComplaints,
    avgResolutionRate,
    healthCounts,
    corpsWithData,
  };
});

// Group by category
const categoryOrder: Array<{ key: FunctionMapping["category"]; label: string }> = [
  { key: "core", label: "Core Functions" },
  { key: "general", label: "General Functions" },
  { key: "sector", label: "Sector Functions" },
];

const grouped = categoryOrder.map(({ key, label }) => ({
  key,
  label,
  items: aggregates.filter((a) => a.fn.category === key),
}));

const categoryLabels: Record<string, string> = {
  core: "Core",
  general: "General",
  sector: "Sector",
};

const devolutionLabels: Record<string, string> = {
  obligatory: "Obligatory",
  discretionary: "Discretionary",
  not_devolved: "Not Devolved",
};
---

<BaseLayout
  title={`${city.act.name} — ${city.name}`}
  description={`Schedule I of the ${city.act.name}: ${mapping.length} mandated functions annotated with budget and complaint data across ${corporations.length} corporations.`}
>
  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: city.name, href: `/${city.id}` },
      { label: city.act.short_name },
    ]}
  />

  <section class="act-header">
    <h1>{city.act.name}</h1>
    <p class="act-subtitle">Schedule I &mdash; Functions of City Corporations</p>
    <p class="text-sm text-muted mt-1">
      Each function mandated by the Act is shown below with current budget allocation and citizen
      complaint data across all {corporations.length} corporations.
    </p>
  </section>

  <dl class="stat-row mt-2">
    <div class="stat-item">
      <dt>Functions</dt>
      <dd>{mapping.length}</dd>
    </div>
    <div class="stat-item">
      <dt>Corporations</dt>
      <dd>{corporations.length}</dd>
    </div>
    <div class="stat-item">
      <dt>Categories</dt>
      <dd>{categoryOrder.length}</dd>
    </div>
    <div class="stat-item">
      <dt>Obligatory</dt>
      <dd>{mapping.filter((fn) => fn.devolution === "obligatory").length}</dd>
    </div>
    <div class="stat-item">
      <dt>Discretionary</dt>
      <dd>{mapping.filter((fn) => fn.devolution === "discretionary").length}</dd>
    </div>
  </dl>

  {grouped.map((group) => (
    <section class="fn-group mt-2">
      <h2 class="group-heading">{group.label}</h2>
      <p class="text-sm text-muted mb-1">
        {group.key === "core"
          ? "Essential civic services that every corporation must deliver"
          : group.key === "general"
            ? "Revenue and regulatory functions of the corporation"
            : "Development and welfare functions for inclusive growth"}
      </p>

      {group.items.map((agg) => (
        <article class="provision-card">
          <div class="provision-header">
            <div class="provision-title-row">
              <h3 class="provision-name">{agg.fn.name}</h3>
              <span class={`cat-badge cat-badge--${agg.fn.category}`}>
                {categoryLabels[agg.fn.category]}
              </span>
              <span class={`dev-badge dev-badge--${agg.fn.devolution}`}>
                {devolutionLabels[agg.fn.devolution]}
              </span>
            </div>
            <p class="text-local">{agg.fn.name_local}</p>
            <p class="provision-ref text-sm text-muted">
              Section {agg.fn.act_reference.section}, Schedule {agg.fn.act_reference.schedule}
            </p>
          </div>

          <blockquote class="act-text">
            &ldquo;{agg.fn.act_reference.text}&rdquo;
          </blockquote>

          <div class="provision-stats">
            <div class="provision-stat">
              <span class="provision-stat__label">Total Budget</span>
              <span class="provision-stat__value">{formatINR(agg.totalBudget)}</span>
              <span class="provision-stat__note">across {agg.corpsWithData} corps</span>
            </div>
            <div class="provision-stat">
              <span class="provision-stat__label">Total Complaints</span>
              <span class="provision-stat__value">{formatNumber(agg.totalComplaints)}</span>
              <span class="provision-stat__note">across {agg.corpsWithData} corps</span>
            </div>
            <div class="provision-stat">
              <span class="provision-stat__label">Avg Resolution</span>
              <span class="provision-stat__value">{agg.avgResolutionRate.toFixed(1)}%</span>
              <span class="provision-stat__note">mean of {agg.corpsWithData} corps</span>
            </div>
          </div>

          <div class="provision-health">
            <span class="provision-health__label">Health across corporations:</span>
            <div class="health-pills">
              {agg.healthCounts.good > 0 && (
                <span class="status-count status-count--good">{agg.healthCounts.good} Good</span>
              )}
              {agg.healthCounts.stressed > 0 && (
                <span class="status-count status-count--stressed">{agg.healthCounts.stressed} Stressed</span>
              )}
              {agg.healthCounts.critical > 0 && (
                <span class="status-count status-count--critical">{agg.healthCounts.critical} Critical</span>
              )}
              {agg.healthCounts.unfunded > 0 && (
                <span class="status-count status-count--unfunded">{agg.healthCounts.unfunded} Unfunded</span>
              )}
            </div>
          </div>

          <div class="provision-footer">
            <a href={`/${city.id}/compare/${agg.fn.id}`} class="compare-link">
              Compare across corporations &rarr;
            </a>
          </div>
        </article>
      ))}
    </section>
  ))}

  <section class="about-act card mt-2">
    <h2>About this Act</h2>
    <p class="mt-1">
      The <strong>{city.act.name}</strong> restructures {city.name}'s civic governance from a single
      BBMP into the <strong>{city.authority}</strong> overseeing {corporations.length} city
      corporations. Schedule I defines the mandatory functions each corporation must perform.
    </p>
    <p class="text-sm text-muted mt-1">
      This page annotates each Schedule I function with live budget and complaint data. Full act text
      extraction is pending &mdash; only function-level provisions are shown currently.
    </p>
  </section>

  <nav class="page-links mt-2">
    <a href={`/${city.id}`} class="link-btn">{city.name} Overview</a>
    <a href={`/${city.id}/compare`} class="link-btn">Compare Corporations</a>
  </nav>
</BaseLayout>

<style>
  /* ── Act Header ──────────────────────────────────────── */
  .act-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-primary);
  }
  .act-subtitle {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--c-text);
    margin-top: 0.15rem;
  }

  /* ── Stat Row (matches corporation page) ─────────────── */
  .stat-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding: 1rem 1.25rem;
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
  }
  .stat-item dt {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }
  .stat-item dd {
    font-size: 1.25rem;
    font-weight: 700;
  }

  /* ── Group Headings ──────────────────────────────────── */
  .fn-group {
    margin-top: 2rem;
  }
  .group-heading {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--c-primary-dark);
    border-bottom: 2px solid var(--c-primary);
    padding-bottom: 0.35rem;
    margin-bottom: 0.5rem;
  }

  /* ── Provision Card ──────────────────────────────────── */
  .provision-card {
    background: var(--c-card);
    border: 1px solid var(--c-border);
    border-left: 4px solid var(--c-primary);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-top: 1rem;
  }

  .provision-header {
    margin-bottom: 0.75rem;
  }

  .provision-title-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.15rem;
  }

  .provision-name {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--c-text);
    margin: 0;
  }

  .provision-ref {
    margin-top: 0.2rem;
  }

  /* ── Category & Devolution Badges ────────────────────── */
  .cat-badge,
  .dev-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cat-badge--core {
    background: #dbeafe;
    color: #1e40af;
  }
  .cat-badge--general {
    background: #fef3c7;
    color: #92400e;
  }
  .cat-badge--sector {
    background: #ede9fe;
    color: #6d28d9;
  }

  .dev-badge--obligatory {
    background: #dcfce7;
    color: #166534;
  }
  .dev-badge--discretionary {
    background: #f3f4f6;
    color: #4b5563;
  }
  .dev-badge--not_devolved {
    background: #fee2e2;
    color: #991b1b;
  }

  /* ── Act Text Blockquote ─────────────────────────────── */
  .act-text {
    font-style: italic;
    font-size: 0.9rem;
    color: var(--c-text);
    background: #f8fafc;
    border-left: 3px solid var(--c-accent);
    padding: 0.6rem 1rem;
    margin: 0 0 0.75rem 0;
    border-radius: 0 var(--radius) var(--radius) 0;
    line-height: 1.5;
  }

  /* ── Provision Stats ─────────────────────────────────── */
  .provision-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .provision-stat {
    display: flex;
    flex-direction: column;
  }

  .provision-stat__label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--c-text-muted);
  }

  .provision-stat__value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-text);
  }

  .provision-stat__note {
    font-size: 0.72rem;
    color: var(--c-text-muted);
  }

  /* ── Health Pills ────────────────────────────────────── */
  .provision-health {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .provision-health__label {
    font-size: 0.82rem;
    color: var(--c-text-muted);
  }

  .health-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .status-count {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius);
  }
  .status-count--good { background: #dcfce7; color: #166534; }
  .status-count--stressed { background: #fef9c3; color: #854d0e; }
  .status-count--critical { background: #fee2e2; color: #991b1b; }
  .status-count--unfunded { background: #f3f4f6; color: #4b5563; }

  /* ── Provision Footer ────────────────────────────────── */
  .provision-footer {
    border-top: 1px solid var(--c-border);
    padding-top: 0.6rem;
  }

  .compare-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-primary);
  }
  .compare-link:hover {
    text-decoration: underline;
  }

  /* ── About Box ───────────────────────────────────────── */
  .about-act h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-primary);
  }

  /* ── Page Links (matches corporation page) ───────────── */
  .page-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .link-btn {
    display: inline-block;
    padding: 0.5rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--c-primary);
    border: 1px solid var(--c-primary);
    border-radius: var(--radius);
    transition: background 0.15s, color 0.15s;
  }
  .link-btn:hover {
    background: var(--c-primary);
    color: #fff;
    text-decoration: none;
  }

  /* ── Responsive ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .act-header h1 {
      font-size: 1.25rem;
    }
    .act-subtitle {
      font-size: 0.95rem;
    }
    .stat-row {
      gap: 1rem;
    }
    .stat-item dd {
      font-size: 1.05rem;
    }
    .provision-card {
      padding: 1rem;
    }
    .provision-title-row {
      gap: 0.35rem;
    }
    .provision-name {
      font-size: 1rem;
    }
    .provision-stats {
      gap: 1rem;
    }
    .provision-stat__value {
      font-size: 0.95rem;
    }
    .status-count {
      font-size: 0.72rem;
      padding: 0.1rem 0.4rem;
    }
  }
</style>
