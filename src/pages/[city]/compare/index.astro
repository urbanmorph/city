---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import HealthBadge from "../../../components/HealthBadge.astro";
import { loadCity, loadCorporations, loadFunctionMapping, loadBudget, loadGrievances } from "../../../lib/data-loader";
import { computeFunctionHealth } from "../../../lib/health-score";
import { formatINR, formatNumber } from "../../../lib/format";
import type { HealthStatus } from "../../../lib/types";

const { city: cityId } = Astro.params;
const city = loadCity(cityId!);
if (!city) return Astro.redirect("/404");

const mapping = loadFunctionMapping(city.id);
const corporations = loadCorporations(city.id);

const corpData = corporations.map((corp) => ({
  corp,
  budget: loadBudget(city.id, corp.id, city.budget_year),
  grievances: loadGrievances(city.id, corp.id),
}));

// For each function, find the worst health status across corps
const functionSummaries = mapping.map((fn) => {
  const statuses: HealthStatus[] = [];
  for (const { corp, budget, grievances } of corpData) {
    if (!budget || !grievances) continue;
    const h = computeFunctionHealth(fn.id, corp.id, budget, grievances, mapping);
    statuses.push(h.status);
  }
  const worst: HealthStatus = statuses.includes("critical") ? "critical"
    : statuses.includes("stressed") ? "stressed"
    : statuses.includes("unfunded") ? "unfunded"
    : "good";
  return { fn, worst, statuses };
});

const categoryLabels: Record<string, string> = { core: "Core", general: "General", sector: "Sector" };
---

<BaseLayout title={`Compare Corporations — ${city.name}`}>
  <Breadcrumb slot="breadcrumb" items={[
    { label: "Home", href: "/" },
    { label: city.name, href: `/${city.id}` },
    { label: "Compare" },
  ]} />

  <section class="compare-header">
    <h1>Compare across {corporations.length} Corporations</h1>
    <p class="text-sm text-muted">Select a function to see how budget allocation and citizen complaints compare across all corporations.</p>
  </section>

  <div class="fn-list mt-2">
    {functionSummaries.map(({ fn, worst }) => (
      <a href={`/${city.id}/compare/${fn.id}`} class="fn-list-item card">
        <div class="fn-list-item__main">
          <span class="fn-list-item__name">{fn.name}</span>
          <span class="fn-list-item__ref text-sm text-muted">S. {fn.act_reference.section} &middot; {categoryLabels[fn.category]}</span>
        </div>
        <HealthBadge status={worst} />
      </a>
    ))}
  </div>
</BaseLayout>

<style>
  .compare-header h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--c-primary);
  }
  .fn-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .fn-list-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    text-decoration: none;
    color: inherit;
    padding: 0.85rem 1.25rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .fn-list-item:hover {
    border-color: var(--c-primary);
    box-shadow: 0 2px 8px rgba(63,95,122,0.1);
    text-decoration: none;
  }
  .fn-list-item__main {
    display: flex;
    flex-direction: column;
  }
  .fn-list-item__name {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--c-primary);
  }
  .fn-list-item__ref {
    margin-top: 0.1rem;
  }
</style>
