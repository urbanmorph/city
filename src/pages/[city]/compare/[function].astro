---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumb from "../../../components/Breadcrumb.astro";
import HealthBadge from "../../../components/HealthBadge.astro";
import { loadCity, loadCorporations, loadFunctionMapping, loadBudget, loadGrievances } from "../../../lib/data-loader";
import { computeFunctionHealth } from "../../../lib/health-score";
import { formatINR, formatPercent, formatNumber } from "../../../lib/format";
import type { FunctionHealth, Corporation, BudgetData, GrievanceData } from "../../../lib/types";

const { city: cityId, function: fnSlug } = Astro.params;

const cityData = loadCity(cityId!);
if (!cityData) return Astro.redirect("/404");

const mapping = loadFunctionMapping(cityId!);
const fnDef = mapping.find((f) => f.id === fnSlug);
if (!fnDef) {
  return new Response(null, { status: 404, statusText: "Function not found" });
}

const corporations = loadCorporations(cityId!);

interface CorpRow {
  corp: Corporation;
  health: FunctionHealth;
  budget: BudgetData;
  grievances: GrievanceData;
}

const rows: CorpRow[] = [];
for (const corp of corporations) {
  const budget = loadBudget(cityId!, corp.id);
  const grievances = loadGrievances(cityId!, corp.id);
  if (!budget || !grievances) continue;

  const health = computeFunctionHealth(fnDef.id, corp.id, budget, grievances, mapping);
  rows.push({ corp, health, budget, grievances });
}

// Sort by stress_index descending (worst first)
rows.sort((a, b) => b.health.stress_index - a.health.stress_index);

// Generate summary insight
function generateInsight(rows: CorpRow[]): string {
  if (rows.length === 0) return "";

  // Worst: highest complaint share with lowest budget share
  const worst = rows[0]; // already sorted by stress_index desc
  // Best: lowest stress index
  const best = rows[rows.length - 1];

  const parts: string[] = [];
  parts.push(
    `${worst.corp.name.replace(/Bengaluru /, "").replace(/ City Corporation/, "")} has the highest stress index (${worst.health.stress_index.toFixed(2)}) with ${formatPercent(worst.health.complaint_share)} of complaints against ${formatPercent(worst.health.budget_share)} of budget.`
  );
  if (best.corp.id !== worst.corp.id) {
    parts.push(
      `${best.corp.name.replace(/Bengaluru /, "").replace(/ City Corporation/, "")} shows the best balance with a stress index of ${best.health.stress_index.toFixed(2)}.`
    );
  }
  return parts.join(" ");
}

const insightText = generateInsight(rows);

// Devolution label
const devolutionLabel = fnDef.devolution === "obligatory"
  ? "Obligatory"
  : fnDef.devolution === "discretionary"
    ? "Discretionary"
    : "Not Devolved";

const pageTitle = `Compare: ${fnDef.name} across corporations`;
const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: cityData.name, href: `/${cityId}` },
  { label: `Compare: ${fnDef.name}` },
];
---

<BaseLayout title={pageTitle} description={`Cross-corporation comparison of ${fnDef.name} for ${cityData.name}`}>
  <Breadcrumb slot="breadcrumb" items={breadcrumbs} />

  <header class="compare-header">
    <h1>{fnDef.name}</h1>
    <p class="text-local">{fnDef.name_local}</p>
    <p class="compare-sub">
      <span class="text-sm">
        S. {fnDef.act_reference.section} &middot; {devolutionLabel} &middot; {cityData.act.short_name}
      </span>
    </p>
  </header>

  <section class="card">
    <h2 class="section-label">Comparison across {rows.length} corporations</h2>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Corporation</th>
            <th>Budget</th>
            <th>% of Total</th>
            <th>Complaints</th>
            <th>% of Total</th>
            <th>Resolution Rate</th>
            <th>Health</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ corp, health }) => (
            <tr>
              <td>
                <a href={`/${cityId}/${corp.id}/${fnDef.id}`}>
                  {corp.name.replace(/Bengaluru /, "").replace(/ City Corporation/, "")}
                </a>
              </td>
              <td>{formatINR(health.budget_amount)}</td>
              <td>{formatPercent(health.budget_share)}</td>
              <td>{formatNumber(health.complaint_count)}</td>
              <td>{formatPercent(health.complaint_share)}</td>
              <td>{health.resolution_rate > 0 ? `${health.resolution_rate}%` : "N/A"}</td>
              <td><HealthBadge status={health.status} /></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {insightText && (
    <section class="card insight-card">
      <h2 class="section-label">Summary Insight</h2>
      <p class="insight-text">{insightText}</p>
    </section>
  )}

  <nav class="compare-nav">
    <a href={`/${cityId}`}>&larr; Back to {cityData.name}</a>
  </nav>
</BaseLayout>

<style>
  /* ── Compare Header ───────────────────────────────────── */
  .compare-header {
    margin-bottom: 1.5rem;
  }
  .compare-header h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--c-primary-dark);
    margin-bottom: 0.15rem;
  }
  .compare-sub {
    margin-top: 0.4rem;
  }

  /* ── Section Label ────────────────────────────────────── */
  .section-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--c-text-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Insight Card ─────────────────────────────────────── */
  .insight-card {
    border-left: 4px solid var(--c-accent);
  }
  .insight-text {
    font-size: 0.92rem;
    line-height: 1.6;
  }

  /* ── Navigation ───────────────────────────────────────── */
  .compare-nav {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--c-border);
    font-size: 0.88rem;
  }

  /* ── Responsive ───────────────────────────────────────── */
  @media (max-width: 640px) {
    .compare-header h1 {
      font-size: 1.25rem;
    }
  }
</style>
