---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CorporationCard from "../../components/CorporationCard.astro";
import { loadCity, loadCorporations, loadBudget, loadLineItemBudget } from "../../lib/data-loader";
import { formatINR } from "../../lib/format";

const { city: cityId } = Astro.params;

const city = loadCity(cityId!);

if (!city) {
  return Astro.redirect("/404");
}

const corporations = loadCorporations(city.id);

type CorpCardData = {
  corporation: (typeof corporations)[number];
  totalBudgetLakhs: number;
  yoyPct: number | null;
  spilloverLakhs: number | null;
  dataStatus: "full" | "partial" | "none";
};

const corpCards: CorpCardData[] = corporations.map((corp) => {
  const lineItems = loadLineItemBudget(city.id, corp.id);

  if (lineItems) {
    return {
      corporation: corp,
      totalBudgetLakhs: lineItems.total_2026_27 ?? 0,
      yoyPct: lineItems.yoy_pct ?? null,
      spilloverLakhs: lineItems.total_spillover ?? null,
      dataStatus: corp.id === "south" ? "partial" : "full",
    };
  }

  const budget = loadBudget(city.id, corp.id, city.budget_year);
  return {
    corporation: corp,
    totalBudgetLakhs: budget?.summary?.total_expenditure ?? 0,
    yoyPct: null,
    spilloverLakhs: null,
    dataStatus: "none",
  };
});

const totalBudgetLakhs = corpCards.reduce((sum, c) => sum + c.totalBudgetLakhs, 0);
const totalWards = corporations.reduce((sum, c) => sum + (c.wards ?? 0), 0);
---

<BaseLayout title={city.name} description={`Budget overview for ${city.name}`}>
  <Breadcrumb
    slot="breadcrumb"
    items={[
      { label: "Home", href: "/" },
      { label: city.name },
    ]}
  />

  <header class="page-head">
    <div class="eyebrow">City Overview, Fiscal Year {city.budget_year}</div>
    <h1>{city.name}</h1>
    <p class="lede">
      Five corporations, one governance Act, tracked rupee by rupee.
    </p>
  </header>

  <section class="topline">
    <div class="tl-cell">
      <span class="tl-label">Total Budget</span>
      <span class="tl-value">{formatINR(totalBudgetLakhs)}</span>
      <span class="tl-sub">{city.budget_year} across {corporations.length} corps</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Corporations</span>
      <span class="tl-value">{corporations.length}</span>
      <span class="tl-sub">Post-trifurcation</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Wards</span>
      <span class="tl-value">{totalWards}</span>
      <span class="tl-sub">Across the city</span>
    </div>
    <div class="tl-cell">
      <span class="tl-label">Act</span>
      <span class="tl-value tl-value--small">{city.act.short_name}</span>
      <span class="tl-sub">Governing statute</span>
    </div>
  </section>

  <h2 class="section-title">Corporations ({corporations.length})</h2>

  <div class="card-grid">
    {corpCards.map((c) => (
      <CorporationCard
        cityId={city.id}
        corporation={c.corporation}
        totalBudgetLakhs={c.totalBudgetLakhs}
        yoyPct={c.yoyPct}
        spilloverLakhs={c.spilloverLakhs}
        dataStatus={c.dataStatus}
      />
    ))}
  </div>
</BaseLayout>

<style>
  :root {
    --num-font: "Inter", ui-sans-serif, system-ui, sans-serif;
    --c-ink: #1a202c;
    --c-ink-soft: #4a5568;
    --c-rule: #e2e8f0;
    --c-rule-soft: #edf2f7;
    --c-neutral: #718096;
  }

  .page-head {
    text-align: left;
    margin: 2rem 0 1.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--c-rule);
  }
  .page-head .eyebrow {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--c-ink-soft);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .page-head h1 {
    text-align: left;
    font-size: clamp(1.75rem, 3.6vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.15;
    color: var(--c-ink);
    margin: 0;
  }
  .page-head .lede {
    margin: 0.75rem 0 0;
    max-width: 68ch;
    color: var(--c-ink-soft);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .topline {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    background: var(--c-card);
    border: 1px solid var(--c-rule);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 1.5rem;
  }
  .tl-cell {
    padding: 1.1rem 1.25rem;
    border-right: 1px solid var(--c-rule);
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    background: #fff;
  }
  .tl-cell:last-child { border-right: none; }
  .tl-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--c-ink-soft);
    font-weight: 600;
  }
  .tl-value {
    font-family: var(--num-font);
    font-feature-settings: "tnum";
    font-variant-numeric: tabular-nums;
    font-size: 1.45rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .tl-value--small {
    font-size: 1.15rem;
    letter-spacing: 0;
  }
  .tl-sub {
    font-size: 0.74rem;
    color: var(--c-neutral);
  }

  .section-title {
    margin: 2rem 0 1rem;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.005em;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 960px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .topline { grid-template-columns: repeat(2, 1fr); }
    .tl-cell { border-right: none; border-bottom: 1px solid var(--c-rule); }
    .tl-cell:nth-child(odd) { border-right: 1px solid var(--c-rule); }
    .tl-cell:last-child, .tl-cell:nth-last-child(2) { border-bottom: none; }
  }

  @media (max-width: 560px) {
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
